<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Settings | skiLLup</title>
    <link rel="stylesheet" href="/settings.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,400;14..32,500;14..32,600;14..32,700;14..32,800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
    <div class="app-container">
        <!-- Sidebar (matching learn.ejs) -->
        <aside class="sidebar">
            <div class="logo">
                <span class="logo-icon">📚</span>
                <span class="logo-text">skiLLup</span>
            </div>
            <nav class="nav-menu">
                <a href="/learn" class="nav-item">
                    <span class="nav-icon">🎓</span>
                    <span>Learn</span>
                </a>
                <a href="/teach" class="nav-item">
                    <span class="nav-icon">👨‍🏫</span>
                    <span>Teach</span>
                </a>
                <a href="/store" class="nav-item">
                    <span class="nav-icon">🛒</span>
                    <span>Store</span>
                </a>
                <a href="/history" class="nav-item">
                    <span class="nav-icon">📜</span>
                    <span>History</span>
                </a>
                <a href="/roadmap" class="nav-item">
                    <span class="nav-icon">🗺️</span>
                    <span>Roadmap</span>
                </a>
                <a href="/settings" class="nav-item active">
                    <span class="nav-icon">⚙️</span>
                    <span>Settings</span>
                </a>
            </nav>
            <div class="user-profile">
                <div class="avatar"><%= user ? user.name.charAt(0).toUpperCase() + (user.name.split(' ')[1] ? user.name.split(' ')[1].charAt(0).toUpperCase() : '') : 'U' %></div>
                <div class="user-info">
                    <span class="user-name"><%= user ? user.name : 'User' %></span>
                    <span class="user-email"><%= user ? user.email : 'user@example.com' %></span>
                </div>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="main-content">
            <!-- Top Bar with Credits Card -->
            <div class="top-bar">
                <div class="header-section">
                    <h1><i class="fas fa-sliders-h"></i> Settings</h1>
                    <p class="header-subtitle">Manage your account preferences</p>
                </div>
                
                <!-- Credits Card -->
                <div class="credits-card">
                    <div class="credits-icon">
                        <i class="fas fa-coins"></i>
                    </div>
                    <div class="credits-info">
                        <span class="credits-label">Available Credits</span>
                        <span class="credits-amount" id="creditAmount">0</span>
                    </div>
                    <button class="add-credits-btn" onclick="window.location.href='/store'">
                        <i class="fas fa-plus"></i> Add
                    </button>
                </div>
            </div>

            <!-- Settings Content -->
            <div class="settings-container">
                <!-- Profile Overview Card -->
                <div class="profile-overview-card">
                    <div class="profile-avatar-section">
                       <div class="profile-avatar-large" id="profileAvatar">
                                 <% if (user && user.avatar) { %>
                               <img src="<%= user.avatar %>" alt="Profile Avatar" style="width:100%;height:100%;object-fit:cover;border-radius:50%;">
                             <% } else { %>
                              <%= user ? user.name.charAt(0).toUpperCase() : 'U' %>
                             <% } %>
                        </div>
                        <button class="change-avatar-btn" id="changeAvatarBtn">
                            <i class="fas fa-camera"></i> Change Photo
                        </button>
                        <input type="file" id="avatarInput" accept="image/*" style="display: none;">
                    </div>
                    <div class="profile-stats">
                        <div class="stat-box">
                            <span class="stat-label">Level</span>
                            <span class="stat-value" id="userLevel"><%= user ? user.level : 1 %></span>
                        </div>
                        <div class="stat-box">
                            <span class="stat-label">Rating</span>
                            <span class="stat-value" id="userRating"><%= user ? user.rating.toFixed(1) : '0.0' %></span>
                            <i class="fas fa-star star-icon"></i>
                        </div>
                        <div class="stat-box">
                            <span class="stat-label">Total Reviews</span>
                            <span class="stat-value" id="userReviews"><%= user ? user.totalReviews : 0 %></span>
                        </div>
                    </div>
                </div>

                <!-- Settings Tabs -->
                <div class="settings-tabs">
                    <button class="tab-btn active" data-tab="profile">
                        <i class="fas fa-user"></i> Personal Info
                    </button>
                    <button class="tab-btn" data-tab="security">
                        <i class="fas fa-lock"></i> Security
                    </button>
                    <button class="tab-btn" data-tab="skills">
                        <i class="fas fa-code"></i> Skills
                    </button>
                    <button class="tab-btn" data-tab="financial">
                        <i class="fas fa-wallet"></i> Financial
                    </button>
                </div>

                <!-- Tab Content: Personal Info -->
                <div class="tab-content active" id="profileTab">
                    <form id="profileForm" class="settings-form">
                        <div class="form-group">
                            <label><i class="fas fa-user"></i> Full Name</label>
                            <input type="text" id="profileName" value="<%= user ? user.name : '' %>" required>
                        </div>
                        
                        <div class="form-group">
                            <label><i class="fas fa-envelope"></i> Email Address</label>
                            <input type="email" id="profileEmail" value="<%= user ? user.email : '' %>" required>
                            <small>Changing your email will require verification</small>
                        </div>
                        
                        <div class="form-group">
                            <label><i class="fas fa-align-left"></i> Bio</label>
                            <textarea id="profileBio" rows="4" maxlength="500" placeholder="Tell others about yourself..."><%= user ? user.bio || '' : '' %></textarea>
                            <small><span id="bioCount">0</span>/500 characters</small>
                        </div>
                        
                        <button type="submit" class="save-btn">
                            <i class="fas fa-save"></i> Save Changes
                        </button>
                    </form>
                </div>

                <!-- Tab Content: Security -->
                <div class="tab-content" id="securityTab">
                    <form id="passwordForm" class="settings-form">
                        <div class="form-group">
                            <label><i class="fas fa-key"></i> Current Password</label>
                            <input type="password" id="currentPassword" required>
                        </div>
                        
                        <div class="form-group">
                            <label><i class="fas fa-lock"></i> New Password</label>
                            <input type="password" id="newPassword" required>
                            <small>Minimum 6 characters</small>
                        </div>
                        
                        <div class="form-group">
                            <label><i class="fas fa-check-circle"></i> Confirm New Password</label>
                            <input type="password" id="confirmPassword" required>
                        </div>
                        
                        <button type="submit" class="save-btn">
                            <i class="fas fa-key"></i> Update Password
                        </button>
                    </form>
                </div>

                <!-- Tab Content: Skills -->
                <div class="tab-content" id="skillsTab">
                    <div class="skills-section">
                        <div class="skills-header">
                            <h3><i class="fas fa-graduation-cap"></i> Skills I Want to Learn</h3>
                            <button class="add-skill-btn" id="addLearningSkillBtn">
                                <i class="fas fa-plus"></i> Add Skill
                            </button>
                        </div>
                        <div class="skills-list" id="learningSkillsList">
                            <!-- Dynamic skills will appear here -->
                        </div>
                    </div>

                    <div class="skills-section">
                        <div class="skills-header">
                            <h3><i class="fas fa-chalkboard-user"></i> Skills I Can Teach</h3>
                            <button class="add-skill-btn" id="addTeachingSkillBtn">
                                <i class="fas fa-plus"></i> Add Skill
                            </button>
                        </div>
                        <div class="skills-list" id="teachingSkillsList">
                            <!-- Dynamic skills will appear here -->
                        </div>
                    </div>
                </div>

                <!-- Tab Content: Financial -->
                <div class="tab-content" id="financialTab">
                    <div class="financial-stats">
                        <div class="financial-card">
                            <div class="financial-icon">
                                <i class="fas fa-coins"></i>
                            </div>
                            <div class="financial-info">
                                <span class="financial-label">Available Credits</span>
                                <span class="financial-value" id="financialCredits">0</span>
                            </div>
                        </div>
                        
                        <div class="financial-card">
                            <div class="financial-icon">
                                <i class="fas fa-chart-line"></i>
                            </div>
                            <div class="financial-info">
                                <span class="financial-label">Total Credits Earned</span>
                                <span class="financial-value" id="totalEarned">0</span>
                            </div>
                        </div>
                        
                        <div class="financial-card">
                            <div class="financial-icon">
                                <i class="fas fa-chart-line"></i>
                            </div>
                            <div class="financial-info">
                                <span class="financial-label">Total Credits Spent</span>
                                <span class="financial-value" id="totalSpent">0</span>
                            </div>
                        </div>
                        
                        <div class="financial-card">
                            <div class="financial-icon">
                                <i class="fas fa-exchange-alt"></i>
                            </div>
                            <div class="financial-info">
                                <span class="financial-label">Redeemable Credits</span>
                                <span class="financial-value" id="redeemableCredits">0</span>
                            </div>
                        </div>
                        
                        <div class="financial-card">
                            <div class="financial-icon">
                                <i class="fas fa-rupee-sign"></i>
                            </div>
                            <div class="financial-info">
                                <span class="financial-label">Money Earned</span>
                                <span class="financial-value" id="moneyEarned">₹0</span>
                            </div>
                        </div>
                        
                        <div class="financial-card">
                            <div class="financial-icon">
                                <i class="fas fa-wallet"></i>
                            </div>
                            <div class="financial-info">
                                <span class="financial-label">Balance</span>
                                <span class="financial-value" id="balance">₹0</span>
                            </div>
                        </div>
                    </div>
                    
                    <% if (user && user.level >= 3) { %>
                        <div class="redeem-section">
                            <h3><i class="fas fa-exchange-alt"></i> Redeem Credits</h3>
                            <p class="redeem-info">You have <strong id="redeemableAmount">0</strong> redeemable credits. 1 credit = ₹10</p>
                            <div class="redeem-form">
                                <input type="number" id="redeemAmount" placeholder="Enter credits to redeem" min="10" step="10">
                                <button id="redeemBtn" class="redeem-btn">
                                    <i class="fas fa-exchange-alt"></i> Redeem
                                </button>
                            </div>
                        </div>
                    <% } %>
                    
                    <% if (user && user.level >= 4) { %>
                        <div class="custom-rate-section">
                            <h3><i class="fas fa-tags"></i> Custom Credit Rate</h3>
                            <p>Set your own credit rate per session (level 4+)</p>
                            <div class="rate-form">
                                <input type="number" id="customRate" placeholder="Credits per session" value="<%= user.customCreditRate || '' %>" step="1" min="1">
                                <button id="updateRateBtn" class="save-rate-btn">
                                    <i class="fas fa-save"></i> Update Rate
                                </button>
                            </div>
                        </div>
                    <% } %>
                </div>
            </div>
        </main>
    </div>

    <!-- Add Skill Modal -->
    <div class="modal" id="addSkillModal">
        <div class="modal-content">
            <div class="modal-header">
                <h3><i class="fas fa-plus-circle"></i> Add Skill</h3>
                <button class="close-modal" id="closeSkillModalBtn">&times;</button>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label>Search for a skill</label>
                    <input type="text" id="skillSearchInput" placeholder="e.g., Python, JavaScript, React...">
                </div>
                <div class="skills-search-results" id="skillSearchResults">
                    <!-- Search results will appear here -->
                </div>
            </div>
        </div>
    </div>

    <script>
        // Get user data from server
        const currentUser = {
            id: '<%= user ? user._id : "" %>',
            name: '<%= user ? user.name : "" %>',
            email: '<%= user ? user.email : "" %>',
            level: <%= user ? user.level : 1 %>,
            credits: <%= user ? user.credits : 0 %>,
            totalCreditsEarned: <%= user ? user.totalCreditsEarned : 0 %>,
            totalCreditsSpent: <%= user ? user.totalCreditsSpent : 0 %>,
            redeemableCredits: <%= user ? user.redeemableCredits : 0 %>,
            moneyEarned: <%= user ? user.moneyEarned : 0 %>,
            balance: <%= user ? user.balance || 0 : 0 %>
        };

        let currentSkillType = null; // 'learn' or 'teach'
        let allSkills = [];

        // Helper function to show toast
        function showToast(message, type = "info") {
            const toast = document.createElement('div');
            toast.className = `toast ${type}`;
            toast.innerHTML = `
                <i class="fas ${type === 'success' ? 'fa-check-circle' : type === 'error' ? 'fa-exclamation-circle' : 'fa-info-circle'}"></i>
                <span>${message}</span>
            `;
            document.body.appendChild(toast);
            setTimeout(() => {
                toast.classList.add('show');
                setTimeout(() => {
                    toast.classList.remove('show');
                    setTimeout(() => toast.remove(), 300);
                }, 3000);
            }, 100);
        }

        // Fetch credits
        async function fetchCredits() {
            try {
                const response = await fetch('/api/learn/credits');
                const data = await response.json();
                if (data.success) {
                    document.getElementById('creditAmount').textContent = data.data.credits.toLocaleString();

                    currentUser.credits = data.data.credits;
                       currentUser.totalCreditsEarned = data.data.totalCreditsEarned;
                     currentUser.totalCreditsSpent = data.data.totalCreditsSpent;
                     currentUser.redeemableCredits = data.data.redeemableCredits;
                     currentUser.moneyEarned = data.data.moneyEarned;
                     return data.data;
                 }
            } catch (error) {
                console.error('Error fetching credits:', error);
            }
            return null;
        }

        // Fetch user skills
        async function fetchUserSkills() {
            try {
                const response = await fetch('/api/settings/skills');
                const data = await response.json();
                if (data.success) {
                    renderSkills(data.data.learningSkills, 'learning');
                    renderSkills(data.data.teachingSkills, 'teaching');
                }
            } catch (error) {
                console.error('Error fetching skills:', error);
            }
        }

        // Render skills list
        function renderSkills(skills, type) {
            const container = document.getElementById(`${type}SkillsList`);
            if (!container) return;
            
            if (!skills || skills.length === 0) {
                container.innerHTML = `<div class="no-skills">No skills added yet. Click "Add Skill" to get started.</div>`;
                return;
            }
            
            container.innerHTML = skills.map(skill => `
                <div class="skill-tag" data-skill-id="${skill._id}">
                    <span>${escapeHtml(skill.name)}</span>
                    <button class="remove-skill" onclick="removeSkill('${skill._id}', '${type}')">
                        <i class="fas fa-times"></i>
                    </button>
                </div>
            `).join('');
        }

        // Remove skill
        async function removeSkill(skillId, type) {
            if (!confirm('Are you sure you want to remove this skill?')) return;
            
            try {
                const response = await fetch(`/api/settings/skills/${skillId}`, {
                    method: 'DELETE',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ type: type === 'learning' ? 'learn' : 'teach' })
                });
                
                const data = await response.json();
                if (data.success) {
                    showToast('Skill removed successfully', 'success');
                    fetchUserSkills();
                } else {
                    showToast(data.message || 'Failed to remove skill', 'error');
                }
            } catch (error) {
                console.error('Error removing skill:', error);
                showToast('Failed to remove skill', 'error');
            }
        }

        // Search skills
        async function searchSkills(query) {
            if (!query.trim()) {
                document.getElementById('skillSearchResults').innerHTML = '<div class="search-placeholder">Type to search for skills...</div>';
                return;
            }
            
            try {
                const response = await fetch(`/api/settings/skills/search?q=${encodeURIComponent(query)}`);
                const data = await response.json();
                if (data.success) {
                    renderSkillSearchResults(data.data);
                }
            } catch (error) {
                console.error('Error searching skills:', error);
            }
        }

        // Render search results
        function renderSkillSearchResults(skills) {
            const container = document.getElementById('skillSearchResults');
            if (!skills || skills.length === 0) {
                container.innerHTML = '<div class="no-results">No skills found</div>';
                return;
            }
            
            container.innerHTML = skills.map(skill => `
                <div class="search-result-item" onclick="addSkill('${skill._id}', '${escapeHtml(skill.name)}')">
                    <i class="fas fa-code"></i>
                    <span>${escapeHtml(skill.name)}</span>
                    <small>${escapeHtml(skill.category || 'General')}</small>
                </div>
            `).join('');
        }

        // Add skill
        async function addSkill(skillId, skillName) {
            if (!currentSkillType) return;
            
            try {
                const response = await fetch('/api/settings/skills', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        skillId: skillId,
                        type: currentSkillType === 'learn' ? 'learn' : 'teach'
                    })
                });
                
                const data = await response.json();
                if (data.success) {
                    showToast(`${skillName} added to your ${currentSkillType === 'learn' ? 'learning' : 'teaching'} skills`, 'success');
                    document.getElementById('addSkillModal').classList.remove('show');
                    fetchUserSkills();
                } else {
                    showToast(data.message || 'Failed to add skill', 'error');
                }
            } catch (error) {
                console.error('Error adding skill:', error);
                showToast('Failed to add skill', 'error');
            }
        }

        // Update profile
        document.getElementById('profileForm')?.addEventListener('submit', async (e) => {
            e.preventDefault();
            
            const formData = {
                name: document.getElementById('profileName').value,
                email: document.getElementById('profileEmail').value,
                bio: document.getElementById('profileBio').value
            };
            
            try {
                const response = await fetch('/api/settings/profile', {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(formData)
                });
                
                const data = await response.json();
                if (data.success) {
                    showToast('Profile updated successfully', 'success');
                    setTimeout(() => location.reload(), 1500);
                } else {
                    showToast(data.message || 'Failed to update profile', 'error');
                }
            } catch (error) {
                console.error('Error updating profile:', error);
                showToast('Failed to update profile', 'error');
            }
        });

        // Update password
        document.getElementById('passwordForm')?.addEventListener('submit', async (e) => {
            e.preventDefault();
            
            const newPassword = document.getElementById('newPassword').value;
            const confirmPassword = document.getElementById('confirmPassword').value;
            
            if (newPassword !== confirmPassword) {
                showToast('Passwords do not match', 'error');
                return;
            }
            
            if (newPassword.length < 6) {
                showToast('Password must be at least 6 characters', 'error');
                return;
            }
            
            const formData = {
                currentPassword: document.getElementById('currentPassword').value,
                newPassword: newPassword
            };
            
            try {
                const response = await fetch('/api/settings/password', {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(formData)
                });
                
                const data = await response.json();
                if (data.success) {
                    showToast('Password updated successfully', 'success');
                    document.getElementById('passwordForm').reset();
                } else {
                    showToast(data.message || 'Failed to update password', 'error');
                }
            } catch (error) {
                console.error('Error updating password:', error);
                showToast('Failed to update password', 'error');
            }
        });

        // Update custom rate
        document.getElementById('updateRateBtn')?.addEventListener('click', async () => {
            const customRate = parseInt(document.getElementById('customRate').value);
            
            if (isNaN(customRate) || customRate < 1) {
                showToast('Please enter a valid rate (minimum 1 credit)', 'error');
                return;
            }
            
            try {
                const response = await fetch('/api/settings/custom-rate', {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ customCreditRate: customRate })
                });
                
                const data = await response.json();
                if (data.success) {
                    showToast('Custom rate updated successfully', 'success');
                } else {
                    showToast(data.message || 'Failed to update rate', 'error');
                }
            } catch (error) {
                console.error('Error updating rate:', error);
                showToast('Failed to update rate', 'error');
            }
        });

        // Redeem credits
        document.getElementById('redeemBtn')?.addEventListener('click', async () => {
            const redeemAmount = parseInt(document.getElementById('redeemAmount').value);
            const maxRedeemable = parseInt(document.getElementById('redeemableAmount').textContent);
            
            if (isNaN(redeemAmount) || redeemAmount < 10) {
                showToast('Minimum redemption is 10 credits', 'error');
                return;
            }
            
            if (redeemAmount > maxRedeemable) {
                showToast(`You only have ${maxRedeemable} redeemable credits`, 'error');
                return;
            }
            
            try {
                const response = await fetch('/api/settings/redeem', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ credits: redeemAmount })
                });
                
                const data = await response.json();
                if (data.success) {
                    showToast(`Successfully redeemed ${redeemAmount} credits for ₹${data.data.amount}`, 'success');
                    setTimeout(() => location.reload(), 1500);
                } else {
                    showToast(data.message || 'Failed to redeem credits', 'error');
                }
            } catch (error) {
                console.error('Error redeeming credits:', error);
                showToast('Failed to redeem credits', 'error');
            }
        });

        // Change avatar
        document.getElementById('changeAvatarBtn')?.addEventListener('click', () => {
            document.getElementById('avatarInput').click();
        });
        
        document.getElementById('avatarInput')?.addEventListener('change', async (e) => {
            const file = e.target.files[0];
            if (!file) return;
            
            const formData = new FormData();
            formData.append('avatar', file);
            
            try {
                const response = await fetch('/api/settings/avatar', {
                    method: 'POST',
                    body: formData
                });
                
                const data = await response.json();
               if (data.success) {
                      showToast('Avatar updated successfully', 'success');

                       const profileAvatar = document.getElementById('profileAvatar');
                          if (profileAvatar && data.data && data.data.avatar) {
                          profileAvatar.innerHTML = `<img src="${data.data.avatar}" alt="Profile Avatar" style="width:100%;height:100%;object-fit:cover;border-radius:50%;">`;
                        }

                         setTimeout(() => location.reload(), 1000);
                 } else {
                    showToast(data.message || 'Failed to update avatar', 'error');
                }
            } catch (error) {
                console.error('Error updating avatar:', error);
                showToast('Failed to update avatar', 'error');
            }
        });

        // Tab switching
        function setupTabs() {
            const tabs = document.querySelectorAll('.tab-btn');
            tabs.forEach(tab => {
                tab.addEventListener('click', () => {
                    const tabId = tab.dataset.tab;
                    tabs.forEach(t => t.classList.remove('active'));
                    tab.classList.add('active');
                    
                    document.querySelectorAll('.tab-content').forEach(content => {
                        content.classList.remove('active');
                    });
                    
                    document.getElementById(`${tabId}Tab`).classList.add('active');
                });
            });
        }

        // Setup skill modals
        function setupSkillModals() {
            document.getElementById('addLearningSkillBtn')?.addEventListener('click', () => {
                currentSkillType = 'learn';
                document.getElementById('addSkillModal').classList.add('show');
                document.getElementById('skillSearchInput').value = '';
                document.getElementById('skillSearchResults').innerHTML = '<div class="search-placeholder">Type to search for skills...</div>';
            });
            
            document.getElementById('addTeachingSkillBtn')?.addEventListener('click', () => {
                currentSkillType = 'teach';
                document.getElementById('addSkillModal').classList.add('show');
                document.getElementById('skillSearchInput').value = '';
                document.getElementById('skillSearchResults').innerHTML = '<div class="search-placeholder">Type to search for skills...</div>';
            });
            
            document.getElementById('closeSkillModalBtn')?.addEventListener('click', () => {
                document.getElementById('addSkillModal').classList.remove('show');
            });
            
            document.getElementById('skillSearchInput')?.addEventListener('input', (e) => {
                searchSkills(e.target.value);
            });
            
            document.getElementById('addSkillModal')?.addEventListener('click', (e) => {
                if (e.target === document.getElementById('addSkillModal')) {
                    document.getElementById('addSkillModal').classList.remove('show');
                }
            });
        }

        // Bio character counter
        function setupBioCounter() {
            const bioTextarea = document.getElementById('profileBio');
            const bioCount = document.getElementById('bioCount');
            
            if (bioTextarea && bioCount) {
                bioCount.textContent = bioTextarea.value.length;
                bioTextarea.addEventListener('input', () => {
                    bioCount.textContent = bioTextarea.value.length;
                });
            }
        }

        // Update financial display
        function updateFinancialDisplay() {
            document.getElementById('financialCredits').textContent = currentUser.credits.toLocaleString();
            document.getElementById('totalEarned').textContent = currentUser.totalCreditsEarned.toLocaleString();
            document.getElementById('totalSpent').textContent = currentUser.totalCreditsSpent.toLocaleString();
            document.getElementById('redeemableCredits').textContent = currentUser.redeemableCredits.toLocaleString();
            document.getElementById('moneyEarned').textContent = `₹${currentUser.moneyEarned.toLocaleString()}`;
            document.getElementById('balance').textContent = `₹${(currentUser.balance || 0).toLocaleString()}`;
            const redeemableAmountEl = document.getElementById('redeemableAmount');
           if (redeemableAmountEl) {
              redeemableAmountEl.textContent = currentUser.redeemableCredits;
            }
        }

        // Escape HTML
        function escapeHtml(text) {
            if (!text) return '';
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }

        // Initialize page
        async function init() {
            await fetchCredits();
            await fetchUserSkills();
            setupTabs();
            setupSkillModals();
            setupBioCounter();
            updateFinancialDisplay();
        }

        document.addEventListener('DOMContentLoaded', init);
    </script>
</body>
</html>