        async function fetchSessions(type = 'upcoming') {
    try {
        let url = '/api/teacher/sessions/upcoming';

        if (type === 'completed') {
            url = '/api/teacher/sessions/completed';
        } else if (type === 'ongoing') {
            url = '/api/teacher/sessions/ongoing';
        }

        const response = await fetch(url);
        const data = await response.json();

        if (data.success) {
            renderSessions(data.data, type);

            if (type === 'upcoming') {
                const upcomingSessions = Array.isArray(data.data) ? data.data : [];
                renderUpcomingPreview(upcomingSessions);
            }
        }
    } catch (error) {
        console.error('Error fetching sessions:', error);
    }
}
        
