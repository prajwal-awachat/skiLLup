        async function fetchIncomingRequests(filter = 'all') {
            try {
                const url = filter === 'all' ? '/api/teacher/requests/incoming' : `/api/teacher/requests/incoming?status=${filter}`;
                const response = await fetch(url);
                const data = await response.json();
                if (data.success) {
                    renderRequests(data.data.requests, data.data.counts);
                    document.getElementById('pendingCount').textContent = data.data.counts.pending || 0;
                }
            } catch (error) {
                console.error('Error fetching requests:', error);
            }
        }
        
