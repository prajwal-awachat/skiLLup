    }).join('');
}
        
       async function startSession(sessionId) {
    try {
        const response = await fetch(`/api/teacher/sessions/${sessionId}/start`, {
            method: 'POST'
        });
        const data = await response.json();
        if (data.success) {
            // Show session codes to teacher
            const startInfo = document.getElementById('startSessionInfo');
            if(startInfo) {
                startInfo.innerHTML = `
                    <div class="session-codes-info">
                        <p><i class="fas fa-check-circle" style="color: #10b981;"></i> Session started successfully!</p>
                        <div class="code-box">
                            <label>Session ID (Share with student):</label>
                            <div class="code-display">${data.data.roomId}</div>
                            <button class="copy-code-btn" data-code="${data.data.roomId}">
                                <i class="fas fa-copy"></i> Copy ID
                            </button>
                        </div>
                        <div class="code-box">
                            <label>Join Code (Share with student):</label>
                            <div class="code-display">${data.data.joinCode}</div>
                            <button class="copy-code-btn" data-code="${data.data.joinCode}">
                                <i class="fas fa-copy"></i> Copy Code
                            </button>
                        </div>
                        <div class="join-link-box">
                            <label>Student Join URL:</label>
                            <div class="join-link">${window.location.origin}/meeting/join/${sessionId}</div>
                            <button class="copy-link-btn" data-link="${window.location.origin}/meeting/join/${sessionId}">
                                <i class="fas fa-copy"></i> Copy Link
                            </button>
                        </div>
                        <div class="warning-note">
                            <i class="fas fa-info-circle"></i>
                            Student needs BOTH Session ID and Join Code to join!
                        </div>
                    </div>
                `;
            }
            
            document.getElementById('sessionCodeBox').style.display = 'block';
            document.getElementById('meetingLinkBox').style.display = 'block';
            document.getElementById('startSessionModal').classList.add('show');
            
            // Add copy functionality
            document.querySelectorAll('.copy-code-btn, .copy-link-btn').forEach(btn => {
                btn.addEventListener('click', () => {
                    const textToCopy = btn.getAttribute('data-code') || btn.getAttribute('data-link');
                    if (textToCopy && navigator.clipboard) {
                        navigator.clipboard.writeText(textToCopy);
                        showToast('Copied to clipboard!', 'success');
                    }
                });
            });
            
            showToast('Session started! Share the codes with student', 'success');
            fetchSessions('upcoming');
        }
    } catch (error) {
        console.error('Error starting session:', error);
        showToast('Failed to start session', 'error');
    }
}
        
        
        async function fetchCreditsAndEarnings() {
            try {
                const response = await fetch('/api/teacher/credits-earnings');
                const data = await response.json();
                if (data.success) {
                    document.getElementById('totalCreditsEarned').textContent = data.data.totalCreditsEarned;
                    document.getElementById('redeemableCredits').textContent = data.data.redeemableCredits;
                    document.getElementById('moneyEarned').textContent = `₹${data.data.moneyEarned}`;
                    renderTransactions(data.data.transactions);
                }
            } catch (error) {
                console.error('Error fetching earnings:', error);
            }
        }
        
        function renderTransactions(transactions) {
            const container = document.getElementById('transactionsList');
            
            if (!transactions || transactions.length === 0) {
                container.innerHTML = '<div class="empty-state"><i class="fas fa-receipt"></i><p>No transactions yet</p></div>';
                return;
            }
            
            container.innerHTML = transactions.map(tx => {
                const date = new Date(tx.createdAt);
                const formattedDate = date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
                const typeIcon = {
                    'credit_purchase': 'fa-plus-circle',
                    'credit_spent': 'fa-minus-circle',
                    'credit_earned': 'fa-plus-circle',
                    'credit_redeemed': 'fa-exchange-alt'
                }[tx.type] || 'fa-circle';
                
                const typeClass = tx.credits > 0 ? 'positive' : 'negative';
                
                return `
                    <div class="transaction-item">
                        <div class="transaction-icon">
                            <i class="fas ${typeIcon}"></i>
                        </div>
                        <div class="transaction-details">
                            <div class="transaction-description">${escapeHtml(tx.description)}</div>
                            <div class="transaction-date">${formattedDate}</div>
                        </div>
                        <div class="transaction-amount ${typeClass}">
                            ${tx.credits > 0 ? '+' : ''}${tx.credits} credits
                        </div>
                    </div>
                `;
            }).join('');
        }
        
        
        function initSocket() {
            if(currentUser.id) {
                socket = io();
                window.socket = socket;
                socket.on('connect', () => {
                    socket.emit('register_user', currentUser.id);
                });
                
                
                socket.on('new_request', (data) => {
                    showToast(`New session request from ${data.studentName}!`, 'info');
                    fetchIncomingRequests('pending');
                });
            }
        }
        
        // Tab switching
        function setupTabs() {
            document.querySelectorAll('.tab-btn').forEach(btn => {
                btn.addEventListener('click', () => {
                    const tabId = btn.getAttribute('data-tab');
                    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
                    document.querySelectorAll('.tab-content').forEach(content => content.classList.remove('active'));
                    btn.classList.add('active');
                    const tabContent = document.getElementById(`${tabId}Tab`);
                    if(tabContent) tabContent.classList.add('active');
                    
                    // Load data for tab
                    if (tabId === 'requests') fetchIncomingRequests('all');
                    else if (tabId === 'sessions') fetchSessions('upcoming');
                    else if (tabId === 'skills') fetchTeacherSkills();
                    else if (tabId === 'earnings') fetchCreditsAndEarnings();
                });
            });
            
            document.querySelectorAll('.filter-chip').forEach(btn => {
                btn.addEventListener('click', () => {
                    document.querySelectorAll('.filter-chip').forEach(b => b.classList.remove('active'));
                    btn.classList.add('active');
                    const filter = btn.getAttribute('data-filter');
                    if (filter) fetchIncomingRequests(filter);
                });
            });
            
            document.querySelectorAll('.subtab-btn').forEach(btn => {
                btn.addEventListener('click', () => {
                    document.querySelectorAll('.subtab-btn').forEach(b => b.classList.remove('active'));
                    btn.classList.add('active');
                    const subtab = btn.getAttribute('data-subtab');
                    if (subtab) fetchSessions(subtab);
                });
            });
            document.querySelectorAll('.view-all').forEach(link => {
    link.addEventListener('click', (e) => {
        e.preventDefault();
        const tabId = link.getAttribute('data-tab');
        if (!tabId) return;

        document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
        document.querySelectorAll('.tab-content').forEach(content => content.classList.remove('active'));

        const targetBtn = document.querySelector(`.tab-btn[data-tab="${tabId}"]`);
        const tabContent = document.getElementById(`${tabId}Tab`);

        if (targetBtn) targetBtn.classList.add('active');
        if (tabContent) tabContent.classList.add('active');

        if (tabId === 'sessions') fetchSessions('upcoming');
    });
});

        }
        
        // Initialize page
        async function init() {
            initSocket();
            setupTabs();
            setTimeout(() => {
    if (!window.chatModule && typeof ChatModule !== 'undefined' && window.socket && window.currentUser) {
        window.chatModule = new ChatModule(window.socket, window.currentUser, {
            apiBase: '/api/teacher'
        });
         }
        }, 300);
            
            await fetchTeacherProfile();
            setupRateForm(); 
            await fetchTrendingTopics();
            await fetchTeacherSkills();
            await fetchIncomingRequests('all');
            await fetchSessions('upcoming');
            await fetchCreditsAndEarnings();
           // await fetchAvailableSkills();
            
            // Event listeners
            const addSkillBtn = document.getElementById('addSkillBtn');
            if(addSkillBtn) {
                addSkillBtn.addEventListener('click', () => {
                    document.getElementById('addSkillModal').classList.add('show');
                });
            }
            
            const refreshTrending = document.getElementById('refreshTrending');
            if(refreshTrending) {
                refreshTrending.addEventListener('click', fetchTrendingTopics);
            }
            
           
            // Modal close buttons
            document.querySelectorAll('.close-modal, .close-modal-btn').forEach(btn => {
                btn.addEventListener('click', () => {
                    document.querySelectorAll('.modal').forEach(modal => modal.classList.remove('show'));
                });
            });

            const closeRateModal = document.getElementById('closeRateModal');
                    if(closeRateModal) {
                     closeRateModal.addEventListener('click', () => {
                     document.getElementById('setRateModal').classList.remove('show');
                            });
                          }
            
            // Add skill form
            const addSkillForm = document.getElementById('addSkillForm');
            if(addSkillForm) {
                addSkillForm.addEventListener('submit', async (e) => {
                    e.preventDefault();
                      const skillNameInput = document.getElementById('skillName');
                      const skillName = skillNameInput ? skillNameInput.value.trim() : '';
                      const proficiencyLevel = document.getElementById('proficiencyLevel');
                       const yearsOfExperienceInput = document.getElementById('yearsExperience');
                      const hourlyRateInput = document.getElementById('hourlyRate');

                 if (!skillName) {
                      showToast('Please enter a skill name', 'error');
                       return;
                     }
                    
                    try {
                        const response = await fetch('/api/teacher/skills', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                           body: JSON.stringify({ 
                               skillName: skillName, 
                              proficiencyLevel: proficiencyLevel ? proficiencyLevel.value : 'beginner', 
                              yearsOfExperience: yearsOfExperienceInput ? parseFloat(yearsOfExperienceInput.value) : 0, 
                              hourlyRate: hourlyRateInput ? (parseInt(hourlyRateInput.value) || undefined) : undefined
                            })
                        });
                        const data = await response.json();
                        if (data.success) {
                            showToast('Skill added successfully', 'success');
                            document.getElementById('addSkillModal').classList.remove('show');
                            if (addSkillForm) addSkillForm.reset();
                            fetchTeacherSkills();
                            fetchTeacherProfile();
                        } else {
                            showToast(data.message || 'Failed to add skill', 'error');
                        }
                    } catch (error) {
                        console.error('Error adding skill:', error);
                        showToast('Failed to add skill', 'error');
                    }
                });
            }
            
            // Accept request form
const acceptRequestForm = document.getElementById('acceptRequestForm');
if(acceptRequestForm) {
    acceptRequestForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        const requestIdInput = document.getElementById('acceptRequestId');
        const requestId = requestIdInput ? requestIdInput.value : '';
        const scheduleDate = document.getElementById('scheduleDate');
        const scheduleTime = document.getElementById('scheduleTime');
        
        // Get values (these can be empty/optional now)
        const scheduledDate = scheduleDate ? scheduleDate.value : '';
        const scheduledTime = scheduleTime ? scheduleTime.value : '';
        
        try {
            const response = await fetch(`/api/teacher/requests/${requestId}/accept`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ 
                    scheduledDate: scheduledDate, 
                    scheduledTime: scheduledTime
                    // No meetingLink field anymore
                })
            });
            const data = await response.json();
            if (data.success) {
                showToast('Request accepted! Session created.', 'success');
                document.getElementById('acceptRequestModal').classList.remove('show');
                fetchIncomingRequests('all');
                fetchSessions('upcoming');
            } else {
                showToast(data.message || 'Failed to accept request', 'error');
            }
        } catch (error) {
            console.error('Error accepting request:', error);
            showToast('Failed to accept request', 'error');
        }
    });
}
            
            // Reject request form
            const rejectRequestForm = document.getElementById('rejectRequestForm');
            if(rejectRequestForm) {
                rejectRequestForm.addEventListener('submit', async (e) => {
                    e.preventDefault();
                    const requestIdInput = document.getElementById('rejectRequestId');
                    const requestId = requestIdInput ? requestIdInput.value : '';
                    const rejectReason = document.getElementById('rejectReason');
                    
                    try {
                        const response = await fetch(`/api/teacher/requests/${requestId}/reject`, {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ reason: rejectReason ? rejectReason.value : '' })
                        });
                        const data = await response.json();
                        if (data.success) {
                            showToast('Request rejected', 'info');
                            document.getElementById('rejectRequestModal').classList.remove('show');
                            fetchIncomingRequests('all');
                        } else {
                            showToast(data.message || 'Failed to reject request', 'error');
                        }
                    } catch (error) {
                        console.error('Error rejecting request:', error);
                        showToast('Failed to reject request', 'error');
                    }
                });
            }
           
            
            // Copy code button in start session modal
            const copyCodeBtn = document.getElementById('copyCodeBtn');
            if(copyCodeBtn) {
                copyCodeBtn.addEventListener('click', () => {
                    const sessionCode = document.getElementById('sessionCode');
                    const code = sessionCode ? sessionCode.textContent : '';
                    if (code && navigator.clipboard) {
                        navigator.clipboard.writeText(code);
                        showToast('Session code copied!', 'success');
                    }
                });
            }
        }
        
        document.addEventListener('DOMContentLoaded', init);
    </script>
</body>
</html>