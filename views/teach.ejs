                btn.addEventListener('click', () => openRejectModal(btn.getAttribute('data-request-id')));
            });

            document.querySelectorAll('.chat-student').forEach(btn => {
                btn.addEventListener('click', () => {
                    try {
                        const student = JSON.parse(btn.getAttribute('data-student'));
                        if (window.chatModule) window.chatModule.openChat(student);
