<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Teacher Dashboard - skiLLup</title>
    <link rel="stylesheet" href="/teach.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,400;14..32,500;14..32,600;14..32,700;14..32,800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="/socket.io/socket.io.js"></script>
</head>
<body>
    <div class="app-container">
        <aside class="sidebar">
            <div class="logo">
                <span class="logo-icon">📚</span>
                <span class="logo-text">skiLLup</span>
            </div>

            <nav class="nav-menu">
                <a href="/learn" class="nav-item">
                    <span class="nav-icon">🎓</span>
                    <span>Learn</span>
                </a>
                <a href="/teach" class="nav-item active">
                    <span class="nav-icon">👨‍🏫</span>
                    <span>Teach</span>
                </a>
                <a href="/store" class="nav-item">
                    <span class="nav-icon">🛒</span>
                    <span>Store</span>
                </a>
                <a href="/history" class="nav-item">
                    <span class="nav-icon">📜</span>
                    <span>History</span>
                </a>
                <a href="/roadmap" class="nav-item">
                    <span class="nav-icon">🗺️</span>
                    <span>Roadmap</span>
                </a>
                <a href="/settings" class="nav-item">
                    <span class="nav-icon">⚙️</span>
                    <span>Settings</span>
                </a>
            </nav>

            <div class="user-profile">
                <div class="avatar">
                    <%= user ? (user.name ? user.name.charAt(0).toUpperCase() + (user.name.split(' ')[1] ? user.name.split(' ')[1].charAt(0).toUpperCase() : '') : 'U') : 'U' %>
                </div>
                <div class="user-info">
                    <span class="user-name"><%= user && user.name ? user.name : 'User' %></span>
                    <span class="user-email"><%= user && user.email ? user.email : 'user@example.com' %></span>
                </div>
            </div>
        </aside>

        <main class="main-content">
            <div class="top-bar">
                <div class="header-section">
                    <h1>Teacher Dashboard</h1>
                    <p class="header-subtitle">Manage requests, sessions, skills, and earnings</p>
                </div>

                <div class="stats-card">
                    <div class="level-badge" id="levelBadge">
                        <i class="fas fa-crown"></i>
                        <span>Level <span id="teacherLevel">1</span></span>
                    </div>

                    <div class="credits-info">
                        <div class="credit-item">
                            <span class="credit-label">Credits</span>
                            <span class="credit-value" id="creditAmount">0</span>
                        </div>
                        <div class="credit-item">
                            <span class="credit-label">Earned</span>
                            <span class="credit-value" id="totalEarned">0</span>
                        </div>
                        <div class="credit-item">
                            <span class="credit-label">Rate/Session</span>
                            <span class="credit-value" id="creditRate">0</span>
                        </div>
                    </div>

                    <div class="rate-control" id="rateControlSection"></div>
                </div>
            </div>

            <div class="level-info" id="levelInfo">
                <div class="level-progress">
                    <div class="level-details">
                        <i class="fas fa-chart-line"></i>
                        <span id="levelDescription">Complete valid sessions to level up!</span>
                    </div>
                    <div class="level-features" id="levelFeatures"></div>
                </div>
            </div>

            <div class="dashboard-tabs">
                <button class="tab-btn active" data-tab="overview">
                    <i class="fas fa-chalkboard-user"></i> Overview
                </button>
                <button class="tab-btn" data-tab="requests">
                    <i class="fas fa-envelope"></i> Requests
                    <span class="badge" id="pendingCount">0</span>
                </button>
                <button class="tab-btn" data-tab="sessions">
                    <i class="fas fa-calendar-alt"></i> Sessions
                </button>
                <button class="tab-btn" data-tab="skills">
                    <i class="fas fa-code"></i> Skills
                </button>
                <button class="tab-btn" data-tab="earnings">
                    <i class="fas fa-wallet"></i> Earnings
                </button>
            </div>

            <!-- OVERVIEW -->
            <div class="tab-content active" id="overviewTab">
                <div class="stats-grid">
                    <div class="stat-card">
                        <i class="fas fa-users"></i>
                        <div class="stat-info">
                            <span class="stat-value" id="totalStudents">0</span>
                            <span class="stat-label">Students Taught</span>
                        </div>
                    </div>

                    <div class="stat-card">
                        <i class="fas fa-clock"></i>
                        <div class="stat-info">
                            <span class="stat-value" id="totalHours">0</span>
                            <span class="stat-label">Teaching Hours</span>
                        </div>
                    </div>

                    <div class="stat-card">
                        <i class="fas fa-star"></i>
                        <div class="stat-info">
                            <span class="stat-value" id="teacherRating">0</span>
                            <span class="stat-label">Rating</span>
                        </div>
                    </div>

                    <div class="stat-card">
                        <i class="fas fa-chart-line"></i>
                        <div class="stat-info">
                            <span class="stat-value" id="completionRate">0%</span>
                            <span class="stat-label">Completion Rate</span>
                        </div>
                    </div>
                </div>

                <div class="section-card">
                    <div class="section-header">
                        <h3><i class="fas fa-fire"></i> Trending Topics to Teach</h3>
                        <button class="refresh-btn" id="refreshTrending">
                            <i class="fas fa-sync-alt"></i>
                        </button>
                    </div>
                    <div class="trending-list" id="trendingList">
                        <div class="loading">Loading trending topics...</div>
                    </div>
                </div>

                <div class="section-card">
                    <div class="section-header">
                        <h3><i class="fas fa-calendar-week"></i> Upcoming Sessions</h3>
                        <a href="#" class="view-all" data-tab="sessions">View All →</a>
                    </div>
                    <div class="upcoming-preview" id="upcomingPreview">
                        <div class="loading">Loading upcoming sessions...</div>
                    </div>
                </div>
            </div>

            <!-- REQUESTS -->
            <div class="tab-content" id="requestsTab">
                <div class="requests-filter">
                    <button class="filter-chip active" data-filter="all">All</button>
                    <button class="filter-chip" data-filter="pending">Pending</button>
                    <button class="filter-chip" data-filter="negotiating">Negotiating</button>
                    <button class="filter-chip" data-filter="confirmed">Confirmed</button>
                    <button class="filter-chip" data-filter="rejected">Rejected</button>
                </div>

                <div class="requests-list" id="requestsList">
                    <div class="loading">Loading requests...</div>
                </div>
            </div>

            <!-- SESSIONS -->
            <div class="tab-content" id="sessionsTab">
                <div class="sessions-subtabs">
                    <button class="subtab-btn active" data-subtab="upcoming">Upcoming</button>
                    <button class="subtab-btn" data-subtab="ongoing">Ongoing</button>
                    <button class="subtab-btn" data-subtab="completed">Completed</button>
                </div>

                <div class="sessions-list" id="sessionsList">
                    <div class="loading">Loading sessions...</div>
                </div>
            </div>

            <!-- SKILLS -->
            <div class="tab-content" id="skillsTab">
                <div class="section-header">
                    <h3><i class="fas fa-code"></i> Your Teaching Skills</h3>
                    <button class="add-btn" id="addSkillBtn">
                        <i class="fas fa-plus"></i> Add Skill
                    </button>
                </div>

                <div class="skills-grid" id="skillsList">
                    <div class="loading">Loading skills...</div>
                </div>
            </div>

            <!-- EARNINGS -->
            <div class="tab-content" id="earningsTab">
                <div class="earnings-summary">
                    <div class="earning-card">
                        <i class="fas fa-coins"></i>
                        <div class="earning-info">
                            <span class="earning-label">Total Credits Earned</span>
                            <span class="earning-value" id="totalCreditsEarned">0</span>
                        </div>
                    </div>

                    <div class="earning-card">
                        <i class="fas fa-exchange-alt"></i>
                        <div class="earning-info">
                            <span class="earning-label">Redeemable Credits</span>
                            <span class="earning-value" id="redeemableCredits">0</span>
                        </div>
                    </div>

                    <div class="earning-card">
                        <i class="fas fa-rupee-sign"></i>
                        <div class="earning-info">
                            <span class="earning-label">Money Earned</span>
                            <span class="earning-value" id="moneyEarned">₹0</span>
                        </div>
                    </div>
                </div>

                <div class="transaction-history">
                    <h3><i class="fas fa-history"></i> Transaction History</h3>
                    <div class="transactions-list" id="transactionsList">
                        <div class="loading">Loading transactions...</div>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <!-- ADD SKILL MODAL -->
    <div class="modal" id="addSkillModal">
        <div class="modal-content">
            <div class="modal-header">
                <h3><i class="fas fa-plus-circle"></i> Add Teaching Skill</h3>
                <button class="close-modal" id="closeSkillModal">&times;</button>
            </div>

            <form id="addSkillForm" class="modal-form">
                <div class="form-group">
                    <label>Skill Name *</label>
                    <input type="text" id="skillName" placeholder="e.g. JavaScript, Python, UI Design" required>
                    <small>Enter the skill you want to teach</small>
                </div>

                <div class="form-group">
                    <label>Proficiency Level</label>
                    <select id="proficiencyLevel">
                        <option value="beginner">Beginner</option>
                        <option value="intermediate">Intermediate</option>
                        <option value="advanced">Advanced</option>
                        <option value="expert">Expert</option>
                    </select>
                </div>

                <div class="form-group">
                    <label>Years of Experience</label>
                    <input type="number" id="yearsExperience" min="0" step="0.5" value="0">
                </div>

                <div class="form-group" id="rateField" style="display:none;">
                    <label>Rate Per Session (Credits)</label>
                    <input type="number" id="hourlyRate" min="1" step="1">
                    <small id="rateHint"></small>
                </div>

                <button type="submit" class="submit-btn">Add Skill</button>
            </form>
        </div>
    </div>

    <!-- ACCEPT REQUEST MODAL -->
    <div class="modal" id="acceptRequestModal">
        <div class="modal-content">
            <div class="modal-header">
                <h3><i class="fas fa-check-circle"></i> Confirm Session Request</h3>
                <button class="close-modal" id="closeAcceptModal">&times;</button>
            </div>

            <form id="acceptRequestForm" class="modal-form">
                <input type="hidden" id="acceptRequestId">
                <div class="request-details" id="requestDetails"></div>

                <div class="info-box-simple">
                    <i class="fas fa-info-circle"></i>
                    This will confirm the currently proposed slot.
                </div>

                <button type="submit" class="accept-submit-btn">Confirm Request</button>
            </form>
        </div>
    </div>

    <!-- SUGGEST SLOT MODAL -->
    <div class="modal" id="suggestSlotModal">
        <div class="modal-content">
            <div class="modal-header">
                <h3><i class="fas fa-calendar-alt"></i> Suggest New Slot</h3>
                <button class="close-modal" id="closeSuggestModal">&times;</button>
            </div>

            <form id="suggestSlotForm" class="modal-form">
                <input type="hidden" id="suggestRequestId">

                <div class="form-group">
                    <label>Proposed Date *</label>
                    <input type="date" id="suggestDate" required>
                </div>

                <div class="form-group">
                    <label>Proposed Start Time *</label>
                    <input type="time" id="suggestTime" required>
                </div>

                <div class="form-group">
                    <label>Message</label>
                    <textarea id="suggestMessage" rows="3" placeholder="Explain the new slot to the student"></textarea>
                </div>

                <button type="submit" class="submit-btn">Send Suggestion</button>
            </form>
        </div>
    </div>

    <!-- REJECT MODAL -->
    <div class="modal" id="rejectRequestModal">
        <div class="modal-content">
            <div class="modal-header">
                <h3><i class="fas fa-times-circle"></i> Reject Session Request</h3>
                <button class="close-modal" id="closeRejectModal">&times;</button>
            </div>

            <form id="rejectRequestForm" class="modal-form">
                <input type="hidden" id="rejectRequestId">

                <div class="form-group">
                    <label>Reason for Rejection</label>
                    <textarea id="rejectReason" rows="3" placeholder="Explain why you're rejecting this request..."></textarea>
                </div>

                <button type="submit" class="reject-submit-btn">Reject Request</button>
            </form>
        </div>
    </div>

    <!-- START SESSION MODAL -->
    <div class="modal" id="startSessionModal">
        <div class="modal-content">
            <div class="modal-header">
                <h3><i class="fas fa-play-circle"></i> Session Started</h3>
                <button class="close-modal" id="closeStartModal">&times;</button>
            </div>

            <div class="modal-form">
                <div id="startSessionInfo"></div>

                <div class="modal-actions">
                    <button class="close-modal-btn" id="closeStartModalBtn" type="button">Close</button>
                </div>
            </div>
        </div>
    </div>

    <!-- SET RATE MODAL -->
    <div class="modal" id="setRateModal">
        <div class="modal-content">
            <div class="modal-header">
                <h3><i class="fas fa-tag"></i> Set Per-Session Rate</h3>
                <button class="close-modal" id="closeRateModal">&times;</button>
            </div>

            <form id="setRateForm" class="modal-form">
                <div class="form-group">
                    <label>Credits per Session *</label>
                    <input type="number" id="sessionRate" min="1" step="1" required>
                    <small>Set how many credits you want to earn per future session</small>
                </div>

                <div class="info-box-simple">
                    <i class="fas fa-info-circle"></i>
                    This rate applies to all your future teaching skills/sessions.
                </div>

                <button type="submit" class="submit-btn">Update Rate</button>
            </form>
        </div>
    </div>

    <%- include('partials/chat-modal') %>

    <script>
        const currentUser = {
            id: '<%= user && user._id ? user._id.toString() : "" %>',
            name: '<%= user && user.name ? user.name.replace(/'/g, "\\'") : "" %>',
            email: '<%= user && user.email ? user.email.replace(/'/g, "\\'") : "" %>',
            level: <%= user && user.level ? user.level : 1 %>
        };

        window.currentUser = currentUser;

        let socket = null;
        let currentConversationId = null;
        let currentChatStudent = null;

        function showToast(message, type = "info") {
            const toast = document.createElement('div');
            toast.className = `toast ${type}`;
            toast.innerHTML = `
                <i class="fas ${type === 'success' ? 'fa-check-circle' : type === 'error' ? 'fa-exclamation-circle' : 'fa-info-circle'}"></i>
                <span>${escapeHtml(message)}</span>
            `;
            document.body.appendChild(toast);

            setTimeout(() => {
                toast.classList.add('show');
                setTimeout(() => {
                    toast.classList.remove('show');
                    setTimeout(() => toast.remove(), 300);
                }, 3000);
            }, 100);
        }

        function escapeHtml(text) {
            if (!text) return '';
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }

        function getRandomColor(str = '') {
            let hash = 0;
            for (let i = 0; i < str.length; i++) {
                hash = str.charCodeAt(i) + ((hash << 5) - hash);
            }
            const hue = Math.abs(hash % 360);
            return `hsl(${hue}, 70%, 60%)`;
        }

        function formatDate(dateValue) {
            if (!dateValue) return 'Not set';
            const date = new Date(dateValue);
            return date.toLocaleDateString('en-US', {
                month: 'short',
                day: 'numeric',
                year: 'numeric'
            });
        }

        async function fetchTeacherProfile() {
            try {
                const response = await fetch('/api/teacher/profile');
                const data = await response.json();

                if (data.success) {
                    document.getElementById('teacherLevel').textContent = data.data.level;
                    document.getElementById('creditAmount').textContent = data.data.user.credits || 0;
                    document.getElementById('totalEarned').textContent = data.data.user.totalCreditsEarned || 0;
                    document.getElementById('creditRate').textContent = data.data.creditRate || 0;
                    document.getElementById('teacherRating').textContent = data.data.user.rating || 0;
                    document.getElementById('totalStudents').textContent = data.data.stats?.totalStudents || data.data.user.studentsCount || 0;
                    document.getElementById('totalHours').textContent = data.data.stats?.totalHours || 0;
                    document.getElementById('completionRate').textContent = `${data.data.stats?.completionRate || 0}%`;

                    updateLevelFeatures(data.data);
                    updateRateControl(data.data);
                    return data.data;
                }
            } catch (error) {
                console.error('Error fetching profile:', error);
            }
            return null;
        }

        function updateLevelFeatures(profileData) {
            const level = profileData.level;
            const levelFeatures = document.getElementById('levelFeatures');

            let featuresHtml = '';
            if (level === 1) {
                featuresHtml = '<span class="feature-badge">📖 Fixed 1 credit/session</span><span class="feature-badge">🔒 No withdrawal</span>';
                document.getElementById('levelDescription').textContent = 'Level 1: Start teaching and earn 1 credit per valid session';
            } else if (level === 2) {
                featuresHtml = '<span class="feature-badge">⭐ Admin-set credits</span><span class="feature-badge">🔒 No withdrawal</span>';
                document.getElementById('levelDescription').textContent = 'Level 2: More value, still admin controlled';
            } else if (level === 3) {
                featuresHtml = '<span class="feature-badge">⭐ Admin-set credits</span><span class="feature-badge">💰 Withdrawal allowed</span>';
                document.getElementById('levelDescription').textContent = 'Level 3: Withdrawals unlocked';
            } else if (level === 4) {
                featuresHtml = '<span class="feature-badge">🎯 Set your own rates</span><span class="feature-badge">💰 Withdrawal allowed</span><span class="feature-badge">👤 One-on-one only</span>';
                document.getElementById('levelDescription').textContent = 'Level 4: You control your pricing';
            } else if (level === 5) {
                featuresHtml = '<span class="feature-badge">🎯 Set your own rates</span><span class="feature-badge">💰 Withdrawal allowed</span><span class="feature-badge">👥 Group sessions</span>';
                document.getElementById('levelDescription').textContent = 'Level 5: Premium teacher features unlocked';
            }

            levelFeatures.innerHTML = featuresHtml;

            const rateField = document.getElementById('rateField');
            const rateHint = document.getElementById('rateHint');

            if (level >= 4) {
                rateField.style.display = 'block';
                rateHint.textContent = `You can set your own rate (current: ${profileData.creditRate} credits/session)`;
            } else {
                rateField.style.display = 'none';
            }
        }

        function updateRateControl(profileData) {
            const rateControlSection = document.getElementById('rateControlSection');
            if (!rateControlSection) return;

            const level = profileData.level;
            const currentRate = profileData.creditRate;

            if (level >= 4) {
                rateControlSection.innerHTML = `
                    <div class="rate-message">
                        <i class="fas fa-star"></i> You can set your own rate
                    </div>
                    <div class="current-rate">Current Rate: ${currentRate} credits/session</div>
                    <button class="set-rate-btn" id="openRateModalBtn">
                        <i class="fas fa-edit"></i> Change Rate
                    </button>
                `;

                document.getElementById('openRateModalBtn')?.addEventListener('click', () => {
                    document.getElementById('setRateModal').classList.add('show');
                    document.getElementById('sessionRate').value = currentRate;
                });
            } else {
                rateControlSection.innerHTML = `
                    <div class="rate-message warning">
                        <i class="fas fa-lock"></i> Custom rate available at Level 4+
                    </div>
                    <div class="current-rate locked-rate">Fixed Rate: ${currentRate} credits/session</div>
                `;
            }
        }

        async function fetchTrendingTopics() {
            try {
                const response = await fetch('/api/teacher/trending-topics');
                const data = await response.json();
                if (data.success) renderTrendingTopics(data.data);
            } catch (error) {
                console.error('Error fetching trending topics:', error);
            }
        }

        function renderTrendingTopics(data) {
            const container = document.getElementById('trendingList');
            const trending = data.trendingSkills || [];

            if (!trending.length) {
                container.innerHTML = `
                    <div class="empty-state">
                        <i class="fas fa-chart-line"></i>
                        <p>No trending topics yet</p>
                    </div>
                `;
                return;
            }

            container.innerHTML = trending.map(skill => `
                <div class="trending-item">
                    <div class="trending-icon">
                        <i class="fas fa-chart-simple"></i>
                    </div>

                    <div class="trending-info">
                        <div class="trending-name">${escapeHtml(skill.name)}</div>
                        <div class="trending-category">${escapeHtml(skill.category)}</div>
                    </div>

                    <div class="trending-stats">
                        <span><i class="fas fa-users"></i> ${skill.totalTeachers || 0} teachers</span>
                    </div>

                    <button class="add-trending-skill" data-skill-name="${escapeHtml(skill.name)}">
                        <i class="fas fa-plus"></i> Add Skill
                    </button>
                </div>
            `).join('');

            document.querySelectorAll('.add-trending-skill').forEach(btn => {
                btn.addEventListener('click', () => {
                    document.getElementById('skillName').value = btn.getAttribute('data-skill-name') || '';
                    document.getElementById('addSkillModal').classList.add('show');
                });
            });
        }

        async function fetchTeacherSkills() {
            try {
                const response = await fetch('/api/teacher/skills');
                const data = await response.json();
                if (data.success) renderTeacherSkills(data.data);
            } catch (error) {
                console.error('Error fetching skills:', error);
            }
        }

        function renderTeacherSkills(skills) {
            const container = document.getElementById('skillsList');

            if (!skills || !skills.length) {
                container.innerHTML = `
                    <div class="empty-state">
                        <i class="fas fa-code"></i>
                        <p>No teaching skills added yet</p>
                        <button class="add-skill-empty" id="addSkillEmptyBtn">Add Your First Skill</button>
                    </div>
                `;

                document.getElementById('addSkillEmptyBtn')?.addEventListener('click', () => {
                    document.getElementById('addSkillModal').classList.add('show');
                });
                return;
            }

            container.innerHTML = skills.map(skill => {
                const skillId = skill.skill?._id || '';
                const skillDataJson = JSON.stringify({
                    skill: skill.skill,
                    proficiencyLevel: skill.proficiencyLevel,
                    yearsOfExperience: skill.yearsOfExperience,
                    hourlyRate: skill.hourlyRate,
                    isAvailable: skill.isAvailable
                }).replace(/</g, '\\u003c').replace(/>/g, '\\u003e').replace(/&/g, '\\u0026').replace(/'/g, '\\u0027');

                return `
                    <div class="skill-card">
                        <div class="skill-header">
                            <div class="skill-name">
                                <i class="fas fa-${getSkillIcon(skill.skill?.category)}"></i>
                                ${escapeHtml(skill.skill?.name || '')}
                            </div>

                            <div class="skill-actions">
                                <button class="edit-skill" data-skill-data="${skillDataJson}">
                                    <i class="fas fa-edit"></i>
                                </button>
                                <button class="delete-skill" data-skill-id="${skillId}">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>
                        </div>

                        <div class="skill-details">
                            <span class="skill-badge">${escapeHtml(skill.proficiencyLevel || 'beginner')}</span>
                            <span class="skill-badge"><i class="fas fa-clock"></i> ${skill.yearsOfExperience || 0} years</span>
                            <span class="skill-badge"><i class="fas fa-coins"></i> ${skill.hourlyRate || 0} credits/session</span>
                            <span class="skill-badge ${skill.isAvailable !== false ? 'available' : 'unavailable'}">
                                <i class="fas ${skill.isAvailable !== false ? 'fa-check-circle' : 'fa-clock'}"></i>
                                ${skill.isAvailable !== false ? 'Available' : 'Unavailable'}
                            </span>
                        </div>
                    </div>
                `;
            }).join('');

            document.querySelectorAll('.edit-skill').forEach(btn => {
                btn.addEventListener('click', () => {
                    try {
                        editSkill(JSON.parse(btn.getAttribute('data-skill-data')));
                    } catch (e) {
                        console.error(e);
                    }
                });
            });

            document.querySelectorAll('.delete-skill').forEach(btn => {
                btn.addEventListener('click', () => deleteSkill(btn.getAttribute('data-skill-id')));
            });
        }

        function getSkillIcon(category) {
            const icons = {
                Programming: 'code',
                'Data Science': 'chart-line',
                Design: 'paintbrush',
                Business: 'briefcase',
                Language: 'language',
                Marketing: 'bullhorn',
                Other: 'star'
            };
            return icons[category] || 'graduation-cap';
        }

        async function editSkill(skillData) {
            const newProficiency = prompt(
                'Enter proficiency level (beginner/intermediate/advanced/expert):',
                skillData.proficiencyLevel
            );

            if (!newProficiency || !['beginner', 'intermediate', 'advanced', 'expert'].includes(newProficiency)) return;

            const newYears = prompt('Enter years of experience:', skillData.yearsOfExperience);
            const isAvailable = confirm('Are you available for this skill? OK = Yes, Cancel = No');

            try {
                const response = await fetch(`/api/teacher/skills/${skillData.skill._id}`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        proficiencyLevel: newProficiency,
                        yearsOfExperience: parseFloat(newYears) || 0,
                        isAvailable
                    })
                });

                const data = await response.json();
                if (data.success) {
                    showToast('Skill updated successfully', 'success');
                    fetchTeacherSkills();
                } else {
                    showToast(data.message || 'Failed to update skill', 'error');
                }
            } catch (error) {
                console.error(error);
                showToast('Failed to update skill', 'error');
            }
        }

        async function deleteSkill(skillId) {
            if (!confirm('Remove this skill?')) return;

            try {
                const response = await fetch(`/api/teacher/skills/${skillId}`, { method: 'DELETE' });
                const data = await response.json();

                if (data.success) {
                    showToast('Skill removed successfully', 'success');
                    fetchTeacherSkills();
                } else {
                    showToast(data.message || 'Failed to remove skill', 'error');
                }
            } catch (error) {
                console.error(error);
                showToast('Failed to remove skill', 'error');
            }
        }

        async function fetchIncomingRequests(filter = 'all') {
            try {
                const url = filter === 'all'
                    ? '/api/teacher/requests/incoming'
                    : `/api/teacher/requests/incoming?status=${encodeURIComponent(filter)}`;

                const response = await fetch(url);
                const data = await response.json();

                if (data.success) {
                    renderRequests(data.data.requests, data.data.counts);
                    document.getElementById('pendingCount').textContent =
                        (data.data.counts.pending || 0) + (data.data.counts.negotiating || 0);
                }
            } catch (error) {
                console.error('Error fetching requests:', error);
            }
        }

        function renderRequests(requests, counts) {
            const container = document.getElementById('requestsList');

            if (!requests || !requests.length) {
                container.innerHTML = `
                    <div class="empty-state">
                        <i class="fas fa-envelope-open-text"></i>
                        <p>No session requests yet</p>
                        <small>Students will request sessions when they find your skills</small>
                    </div>
                `;
                return;
            }

            container.innerHTML = requests.map(request => {
                const student = request.student || {};
                const studentName = student.name || 'Student';
                const studentInitials = studentName.split(' ').map(n => n[0]).join('').toUpperCase().substring(0, 2);

                const dateText = formatDate(request.currentProposedDate);
                const timeText = request.currentStartTime || '--';
                const status = request.status || 'pending';

                let statusClass = status;
                let statusIcon = 'fa-clock';
                let actionButtons = '';

              if (status === 'pending') {
    statusIcon = 'fa-clock';

    actionButtons = `
        <button class="accept-request" data-request-id="${request._id}">
            <i class="fas fa-check-circle"></i> Confirm
        </button>
        <button class="suggest-request" 
            data-request-id="${request._id}"
            data-duration="${request.duration || 60}">
            <i class="fas fa-calendar-alt"></i> Suggest Slot
        </button>
        <button class="reject-request" data-request-id="${request._id}">
            <i class="fas fa-times-circle"></i> Reject
        </button>
    `;
} else if (status === 'negotiating') {
    statusIcon = 'fa-arrows-rotate';

    const isTeacherWaiting = String(request.proposedBy) === String(currentUser.id);

    if (isTeacherWaiting) {
        actionButtons = `
            <span class="waiting-note">
                <i class="fas fa-hourglass-half"></i> Waiting for student response
            </span>
        `;
    } else {
        actionButtons = `
            <button class="accept-request" data-request-id="${request._id}">
                <i class="fas fa-check-circle"></i> Confirm
            </button>
            <button class="suggest-request" 
                data-request-id="${request._id}"
                data-duration="${request.duration || 60}">
                <i class="fas fa-calendar-alt"></i> Suggest Slot
            </button>
            <button class="reject-request" data-request-id="${request._id}">
                <i class="fas fa-times-circle"></i> Reject
            </button>
        `;
    }
} else if (status === 'confirmed') {
                    statusIcon = 'fa-check-circle';

                    const studentData = JSON.stringify({
                        id: student._id,
                        name: student.name
                    }).replace(/'/g, '&apos;');

                    actionButtons = `
                        <button class="chat-student" data-student='${studentData}'>
                            <i class="fas fa-comment-dots"></i> Chat
                        </button>
                    `;
                } else if (status === 'rejected') {
                    statusIcon = 'fa-times-circle';
                    actionButtons = `
                        <span class="request-note reject-note">${escapeHtml(request.teacherMessage || 'Rejected')}</span>
                    `;
                } else if (status === 'expired') {
                    statusIcon = 'fa-hourglass-end';
                    actionButtons = `
                        <span class="request-note expired-note">${escapeHtml(request.expiredReason || 'Expired')}</span>
                    `;
                }

                return `
                    <div class="request-card ${statusClass}">
                        <div class="request-header">
                            <div class="student-info">
                                <div class="student-avatar" style="background:${getRandomColor(student._id || studentName)}">
                                    ${studentInitials}
                                </div>

                                <div class="student-details">
                                    <div class="student-name">${escapeHtml(studentName)}</div>
                                    <div class="request-title">${escapeHtml(request.title || 'Session Request')}</div>
                                </div>
                            </div>

                            <div class="request-status ${statusClass}">
                                <i class="fas ${statusIcon}"></i> ${status.toUpperCase()}
                            </div>
                        </div>

                        <div class="request-body">
                            <div class="request-detail">
                                <i class="fas fa-graduation-cap"></i>
                                <span>${escapeHtml(request.skill?.name || 'Skill')}</span>
                            </div>

                            <div class="request-detail">
                                <i class="fas fa-calendar-alt"></i>
                                <span>${dateText} at ${escapeHtml(timeText)}</span>
                            </div>

                            <div class="request-detail">
                                <i class="fas fa-clock"></i>
                                <span>${request.duration || 60} minutes</span>
                            </div>

                            <div class="request-detail">
                                <i class="fas fa-coins"></i>
                                <span>${request.proposedCredits || 0} credits</span>
                            </div>

                            ${request.description ? `
                                <div class="request-description">
                                    <i class="fas fa-comment"></i>
                                    <p>${escapeHtml(request.description)}</p>
                                </div>
                            ` : ''}

                            ${request.studentMessage ? `
                                <div class="request-note">
                                    <i class="fas fa-message"></i>
                                    <span><strong>Student:</strong> ${escapeHtml(request.studentMessage)}</span>
                                </div>
                            ` : ''}

                            ${request.teacherMessage && status === 'negotiating' ? `
                                <div class="request-note teacher-note">
                                    <i class="fas fa-reply"></i>
