        function openAcceptModal(requestId) {
            document.getElementById('acceptRequestId').value = requestId;
            document.getElementById('requestDetails').innerHTML = `
                <div class="request-summary">
                    <p>This will confirm the currently proposed date and time for this request.</p>
                </div>
            `;
            document.getElementById('acceptRequestModal').classList.add('show');
        }

        function openSuggestModal(requestId, duration) {
            document.getElementById('suggestRequestId').value = requestId;
            
            const today = new Date();
            today.setHours(0,0,0,0);
            document.getElementById('suggestDate').min = today.toISOString().split('T')[0];

            document.getElementById('suggestSlotModal').classList.add('show');
        }

        function openRejectModal(requestId) {
            document.getElementById('rejectRequestId').value = requestId;
            document.getElementById('rejectRequestModal').classList.add('show');
        }

        async function fetchSessions(type = 'upcoming') {
            try {
                let url = '/api/teacher/sessions/upcoming';
                if (type === 'ongoing') url = '/api/teacher/sessions/ongoing';
                if (type === 'completed') url = '/api/teacher/sessions/completed';

                const response = await fetch(url);
                const data = await response.json();

                if (data.success) {
                    renderSessions(data.data, type);
                    if (type === 'upcoming') renderUpcomingPreview(Array.isArray(data.data) ? data.data : []);
                }
            } catch (error) {
                console.error('Error fetching sessions:', error);
            }
        }

        function renderSessions(sessions, type) {
            const container = document.getElementById('sessionsList');

            if (!sessions || (Array.isArray(sessions) && !sessions.length) || (type === 'completed' && !(sessions.sessions || []).length)) {
                container.innerHTML = `
                    <div class="empty-state">
                        <i class="fas fa-calendar-alt"></i>
                        <p>No ${type} sessions found</p>
                    </div>
                `;
                return;
            }

            const sessionsArray = type === 'completed' ? sessions.sessions : sessions;

            container.innerHTML = sessionsArray.map(session => {
                const student = session.student || {};
                const studentName = student.name || 'Student';
                const studentInitials = studentName.split(' ').map(n => n[0]).join('').toUpperCase().substring(0, 2);

                const studentJSON = JSON.stringify({
                    id: student._id,
                    name: student.name
                }).replace(/'/g, '&apos;');

                let actionButtons = '';

                if (type === 'upcoming' && session.status !== 'ongoing') {
                    actionButtons = `
                        <button class="start-session" data-session-id="${session._id}">
                            <i class="fas fa-play"></i> Start Session
                        </button>
                        <button class="chat-student" data-student='${studentJSON}'>
                            <i class="fas fa-comment-dots"></i> Chat
                        </button>
                    `;
                } else if (session.status === 'ongoing') {
                    actionButtons = `
                        <a href="/meeting/join/${session._id}" class="join-session-btn" target="_blank">
                            <i class="fas fa-video"></i> Join Session
                        </a>
                        <button class="chat-student" data-student='${studentJSON}'>
                            <i class="fas fa-comment-dots"></i> Chat
                        </button>
                    `;
                } else if (type === 'completed') {
                    actionButtons = `
                        <span class="request-note">${session.sessionValidity || 'completed'}</span>
                    `;
                }

                return `
                    <div class="session-card">
                        <div class="session-header">
                            <div class="session-student">
                                <div class="student-avatar small" style="background:${getRandomColor(student._id || studentName)}">
                                    ${studentInitials}
                                </div>
                                <div class="session-info">
                                    <div class="student-name">${escapeHtml(studentName)}</div>
                                    <div class="session-title">${escapeHtml(session.title || 'Session')}</div>
                                </div>
                            </div>

                            <div class="session-status ${session.status || 'confirmed'}">
                                <i class="fas ${session.status === 'ongoing' ? 'fa-play-circle' : session.status === 'completed' ? 'fa-check-circle' : 'fa-calendar'}"></i>
                                ${(session.status || 'confirmed').toUpperCase()}
                            </div>
                        </div>

                        <div class="session-body">
                            <div class="session-detail">
                                <i class="fas fa-calendar-alt"></i>
                                <span>${formatDate(session.scheduledDate)} at ${escapeHtml(session.scheduledTime || '--')}</span>
                            </div>

                            <div class="session-detail">
                                <i class="fas fa-clock"></i>
                                <span>${session.duration || 60} minutes</span>
                            </div>

                            <div class="session-detail">
                                <i class="fas fa-coins"></i>
                                <span>${session.creditsPerSession || 0} credits</span>
                            </div>

                            ${session.roomId || session.joinCode ? `
                                <div class="session-code">
                                    <span class="code-label">Session ID:</span>
                                    <span class="code-value">${escapeHtml(session.roomId || '')}</span>
                                </div>
                            ` : ''}
                        </div>

                        <div class="session-actions">
                            ${actionButtons}
                        </div>
                    </div>
                `;
            }).join('');

            document.querySelectorAll('.start-session').forEach(btn => {
                btn.addEventListener('click', () => startSession(btn.getAttribute('data-session-id')));
            });

            document.querySelectorAll('.chat-student').forEach(btn => {
                btn.addEventListener('click', () => {
                    try {
                        const student = JSON.parse(btn.getAttribute('data-student'));
                        if (window.chatModule) window.chatModule.openChat(student);
                    } catch (e) {
                        console.error(e);
                    }
                });
            });
        }

        function renderUpcomingPreview(sessions) {
            const container = document.getElementById('upcomingPreview');
            if (!container) return;

            if (!sessions || !sessions.length) {
                container.innerHTML = `
                    <div class="empty-state">
                        <i class="fas fa-calendar-times"></i>
                        <p>No upcoming sessions</p>
                    </div>
                `;
                return;
            }

            const previewSessions = sessions.slice(0, 3);

            container.innerHTML = previewSessions.map(session => `
                <div class="session-card preview-card">
                    <div class="session-header">
                        <div class="session-info">
                            <div class="student-name">${escapeHtml(session.student?.name || 'Student')}</div>
                            <div class="session-title">${escapeHtml(session.title || 'Session')}</div>
                        </div>
                        <div class="session-status ${session.status || 'confirmed'}">
                            ${(session.status || 'confirmed').toUpperCase()}
                        </div>
                    </div>
                    <div class="session-body">
                        <div class="session-detail">
                            <i class="fas fa-calendar-alt"></i>
                            <span>${formatDate(session.scheduledDate)} at ${escapeHtml(session.scheduledTime || '--')}</span>
                        </div>
                        <div class="session-detail">
                            <i class="fas fa-clock"></i>
                            <span>${session.duration || 60} minutes</span>
                        </div>
                    </div>
                </div>
            `).join('');
        }

        async function startSession(sessionId) {
            try {
                const response = await fetch(`/api/teacher/sessions/${sessionId}/start`, {
                    method: 'POST'
                });
                const data = await response.json();

                if (data.success) {
                    const startInfo = document.getElementById('startSessionInfo');
                    startInfo.innerHTML = `
                        <div class="session-codes-info">
                            <p><i class="fas fa-check-circle" style="color:#10b981;"></i> Session started successfully</p>

                            <div class="code-box">
                                <label>Session ID</label>
                                <div class="code-display">${escapeHtml(data.data.roomId)}</div>
                                <button class="copy-code-btn" data-copy="${escapeHtml(data.data.roomId)}">
                                    <i class="fas fa-copy"></i> Copy ID
                                </button>
                            </div>

                            <div class="code-box">
                                <label>Join Code</label>
                                <div class="code-display">${escapeHtml(data.data.joinCode)}</div>
                                <button class="copy-code-btn" data-copy="${escapeHtml(data.data.joinCode)}">
                                    <i class="fas fa-copy"></i> Copy Code
                                </button>
                            </div>

                            <div class="warning-note">
                                <i class="fas fa-info-circle"></i>
                                Share both Session ID and Join Code with the student
                            </div>
                        </div>
                    `;

                    document.getElementById('startSessionModal').classList.add('show');

                    document.querySelectorAll('.copy-code-btn').forEach(btn => {
                        btn.addEventListener('click', async () => {
                            await navigator.clipboard.writeText(btn.getAttribute('data-copy'));
                            showToast('Copied to clipboard', 'success');
                        });
                    });

                    showToast('Session started', 'success');
                    fetchSessions('upcoming');
                } else {
                    showToast(data.message || 'Failed to start session', 'error');
                }
            } catch (error) {
                console.error(error);
                showToast('Failed to start session', 'error');
            }
        }

        async function fetchCreditsAndEarnings() {
            try {
                const response = await fetch('/api/teacher/credits-earnings');
                const data = await response.json();

                if (data.success) {
                    document.getElementById('totalCreditsEarned').textContent = data.data.totalCreditsEarned || 0;
                    document.getElementById('redeemableCredits').textContent = data.data.redeemableCredits || 0;
                    document.getElementById('moneyEarned').textContent = `₹${data.data.moneyEarned || 0}`;
                    renderTransactions(data.data.transactions || []);
                }
            } catch (error) {
                console.error('Error fetching earnings:', error);
            }
        }

        function renderTransactions(transactions) {
            const container = document.getElementById('transactionsList');

            if (!transactions.length) {
                container.innerHTML = `
                    <div class="empty-state">
                        <i class="fas fa-receipt"></i>
                        <p>No transactions yet</p>
                    </div>
                `;
                return;
            }

            container.innerHTML = transactions.map(tx => {
                const typeIcon = {
                    credit_purchase: 'fa-plus-circle',
                    credit_spent: 'fa-minus-circle',
                    credit_earned: 'fa-plus-circle',
                    credit_redeemed: 'fa-exchange-alt',
                    refund: 'fa-rotate-left'
                }[tx.type] || 'fa-circle';

                return `
                    <div class="transaction-item">
                        <div class="transaction-icon">
                            <i class="fas ${typeIcon}"></i>
                        </div>

                        <div class="transaction-details">
                            <div class="transaction-description">${escapeHtml(tx.description || '')}</div>
                            <div class="transaction-date">${formatDate(tx.createdAt)}</div>
                        </div>

                        <div class="transaction-amount ${tx.credits > 0 ? 'positive' : 'negative'}">
                            ${tx.credits > 0 ? '+' : ''}${tx.credits} credits
                        </div>
                    </div>
                `;
            }).join('');
        }

        function initSocket() {
            if (!currentUser.id) return;

            socket = io();
            window.socket = socket;

            socket.on('connect', () => {
                socket.emit('register_user', currentUser.id);
            });

            socket.on('new_request', (data) => {
                showToast(`New session request from ${data.studentName}!`, 'info');
                fetchIncomingRequests('all');
            });
        }

        function setupTabs() {
            document.querySelectorAll('.tab-btn').forEach(btn => {
                btn.addEventListener('click', () => {
                    const tabId = btn.getAttribute('data-tab');
                    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
                    document.querySelectorAll('.tab-content').forEach(content => content.classList.remove('active'));

                    btn.classList.add('active');
                    document.getElementById(`${tabId}Tab`)?.classList.add('active');

                    if (tabId === 'requests') fetchIncomingRequests('all');
                    if (tabId === 'sessions') fetchSessions('upcoming');
                    if (tabId === 'skills') fetchTeacherSkills();
                    if (tabId === 'earnings') fetchCreditsAndEarnings();
                });
            });

            document.querySelectorAll('.filter-chip').forEach(btn => {
                btn.addEventListener('click', () => {
                    document.querySelectorAll('.filter-chip').forEach(b => b.classList.remove('active'));
                    btn.classList.add('active');
                    fetchIncomingRequests(btn.getAttribute('data-filter'));
                });
            });

            document.querySelectorAll('.subtab-btn').forEach(btn => {
                btn.addEventListener('click', () => {
                    document.querySelectorAll('.subtab-btn').forEach(b => b.classList.remove('active'));
                    btn.classList.add('active');
                    fetchSessions(btn.getAttribute('data-subtab'));
                });
            });

            document.querySelectorAll('.view-all').forEach(link => {
                link.addEventListener('click', (e) => {
                    e.preventDefault();
                    document.querySelector('.tab-btn[data-tab="sessions"]')?.click();
                });
            });
        }

        function setupRateForm() {
            document.getElementById('setRateForm')?.addEventListener('submit', async (e) => {
                e.preventDefault();

                const newRate = parseInt(document.getElementById('sessionRate').value);
                if (!newRate || newRate < 1) {
                    showToast('Please enter a valid rate', 'error');
                    return;
                }

                try {
                    const response = await fetch('/api/teacher/level/credit-rate', {
                        method: 'PUT',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ creditRate: newRate })
                    });

                    const data = await response.json();
                    if (data.success) {
                        showToast('Rate updated successfully', 'success');
                        document.getElementById('setRateModal').classList.remove('show');
                        fetchTeacherProfile();
                    } else {
                        showToast(data.message || 'Failed to update rate', 'error');
                    }
                } catch (error) {
                    console.error(error);
                    showToast('Failed to update rate', 'error');
                }
            });
        }

        function setupModalClosing() {
            document.querySelectorAll('.close-modal, .close-modal-btn').forEach(btn => {
                btn.addEventListener('click', () => {
                    document.querySelectorAll('.modal').forEach(modal => modal.classList.remove('show'));
                });
            });

            document.querySelectorAll('.modal').forEach(modal => {
                modal.addEventListener('click', (e) => {
                    if (e.target === modal) modal.classList.remove('show');
                });
            });
        }

        function setupForms() {
            document.getElementById('addSkillBtn')?.addEventListener('click', () => {
                document.getElementById('addSkillModal').classList.add('show');
            });

            document.getElementById('refreshTrending')?.addEventListener('click', fetchTrendingTopics);

            document.getElementById('addSkillForm')?.addEventListener('submit', async (e) => {
                e.preventDefault();

                const payload = {
                    skillName: document.getElementById('skillName').value.trim(),
                    proficiencyLevel: document.getElementById('proficiencyLevel').value,
                    yearsOfExperience: parseFloat(document.getElementById('yearsExperience').value) || 0,
                    hourlyRate: document.getElementById('hourlyRate').value ? parseInt(document.getElementById('hourlyRate').value) : undefined
                };

                if (!payload.skillName) {
                    showToast('Please enter a skill name', 'error');
                    return;
                }

                try {
                    const response = await fetch('/api/teacher/skills', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(payload)
                    });

                    const data = await response.json();
                    if (data.success) {
                        showToast('Skill added successfully', 'success');
                        document.getElementById('addSkillModal').classList.remove('show');
                        document.getElementById('addSkillForm').reset();
                        fetchTeacherSkills();
                        fetchTeacherProfile();
                    } else {
                        showToast(data.message || 'Failed to add skill', 'error');
                    }
                } catch (error) {
                    console.error(error);
                    showToast('Failed to add skill', 'error');
                }
            });

            document.getElementById('acceptRequestForm')?.addEventListener('submit', async (e) => {
                e.preventDefault();

                const requestId = document.getElementById('acceptRequestId').value;

                try {
                    const response = await fetch(`/api/teacher/requests/${requestId}/accept`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({})
                    });

                    const data = await response.json();
                    if (data.success) {
                        showToast('Request confirmed successfully', 'success');
                        document.getElementById('acceptRequestModal').classList.remove('show');
                        fetchIncomingRequests('all');
                        fetchSessions('upcoming');
                    } else {
                        showToast(data.message || 'Failed to confirm request', 'error');
                    }
                } catch (error) {
                    console.error(error);
                    showToast('Failed to confirm request', 'error');
                }
            });

            document.getElementById('suggestSlotForm')?.addEventListener('submit', async (e) => {
                e.preventDefault();

                const requestId = document.getElementById('suggestRequestId').value;

                const payload = {
                    proposedDate: document.getElementById('suggestDate').value,
                    proposedStartTime: document.getElementById('suggestTime').value,
                    duration:60,
                    message: document.getElementById('suggestMessage').value.trim()
                };

                try {
                    const response = await fetch(`/api/teacher/requests/${requestId}/suggest`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(payload)
                    });

                    const data = await response.json();
                    if (data.success) {
                        showToast('New slot suggested', 'success');
                        document.getElementById('suggestSlotModal').classList.remove('show');
                        document.getElementById('suggestSlotForm').reset();
                        fetchIncomingRequests('all');
                    } else {
                        showToast(data.message || 'Failed to suggest slot', 'error');
                    }
                } catch (error) {
                    console.error(error);
                    showToast('Failed to suggest slot', 'error');
                }
            });

            document.getElementById('rejectRequestForm')?.addEventListener('submit', async (e) => {
                e.preventDefault();

                const requestId = document.getElementById('rejectRequestId').value;
                const reason = document.getElementById('rejectReason').value.trim();

                try {
                    const response = await fetch(`/api/teacher/requests/${requestId}/reject`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ reason })
                    });

                    const data = await response.json();
                    if (data.success) {
                        showToast('Request rejected', 'info');
                        document.getElementById('rejectRequestModal').classList.remove('show');
                        document.getElementById('rejectRequestForm').reset();
                        fetchIncomingRequests('all');
                    } else {
                        showToast(data.message || 'Failed to reject request', 'error');
                    }
                } catch (error) {
                    console.error(error);
                    showToast('Failed to reject request', 'error');
                }
            });
        }

        async function init() {
            initSocket();
            setupTabs();
            setupModalClosing();
            setupForms();
            setupRateForm();

            setTimeout(() => {
                if (!window.chatModule && typeof ChatModule !== 'undefined' && window.socket && window.currentUser) {
                    window.chatModule = new ChatModule(window.socket, window.currentUser, {
                        apiBase: '/api/teacher'
                    });
                }
            }, 300);

            await fetchTeacherProfile();
            await fetchTrendingTopics();
            await fetchTeacherSkills();
            await fetchIncomingRequests('all');
            await fetchSessions('upcoming');
            await fetchCreditsAndEarnings();
        }

        document.addEventListener('DOMContentLoaded', init);
    </script>
</body>
</html>