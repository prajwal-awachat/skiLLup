<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Teacher Dashboard - skiLLup</title>
    <link rel="stylesheet" href="/teach.css">
    
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,400;14..32,500;14..32,600;14..32,700;14..32,800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="/socket.io/socket.io.js"></script>
</head>
<body>
    <div class="app-container">
        <!-- Sidebar -->
        <aside class="sidebar">
            <div class="logo">
                <span class="logo-icon">📚</span>
                <span class="logo-text">skiLLup</span>
            </div>
            <nav class="nav-menu">
                <a href="/learn" class="nav-item">
                    <span class="nav-icon">🎓</span>
                    <span>Learn</span>
                </a>
                <a href="/teach" class="nav-item active">
                    <span class="nav-icon">👨‍🏫</span>
                    <span>Teach</span>
                </a>
                <a href="/store" class="nav-item">
                    <span class="nav-icon">🛒</span>
                    <span>Store</span>
                </a>
                <a href="/history" class="nav-item">
                    <span class="nav-icon">📜</span>
                    <span>History</span>
                </a>
                <a href="/roadmap" class="nav-item">
                    <span class="nav-icon">🗺️</span>
                    <span>Roadmap</span>
                </a>
                <a href="/settings" class="nav-item">
                    <span class="nav-icon">⚙️</span>
                    <span>Settings</span>
                </a>
            </nav>
            <div class="user-profile">
                <div class="avatar"><%= user ? (user.name ? user.name.charAt(0).toUpperCase() + (user.name.split(' ')[1] ? user.name.split(' ')[1].charAt(0).toUpperCase() : '') : 'U') : 'U' %></div>
                <div class="user-info">
                    <span class="user-name"><%= user && user.name ? user.name : 'User' %></span>
                    <span class="user-email"><%= user && user.email ? user.email : 'user@example.com' %></span>
                </div>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="main-content">
            <!-- Header with Level Badge -->
            <div class="top-bar">
                <div class="header-section">
                    <h1>Teacher Dashboard</h1>
                    <p class="header-subtitle">Manage your teaching skills and sessions</p>
                </div>
                
                <!-- Level & Credits Card -->
                <div class="stats-card">
                    <div class="level-badge" id="levelBadge">
                        <i class="fas fa-crown"></i>
                        <span>Level <span id="teacherLevel">1</span></span>
                    </div>
                    <div class="credits-info">
                        <div class="credit-item">
                            <span class="credit-label">Credits</span>
                            <span class="credit-value" id="creditAmount">0</span>
                        </div>
                        <div class="credit-item">
                            <span class="credit-label">Earned</span>
                            <span class="credit-value" id="totalEarned">0</span>
                        </div>
                        <div class="credit-item">
                            <span class="credit-label">Rate/Session</span>
                            <span class="credit-value" id="creditRate">0</span>
                        </div>
                    </div>
                      <div class="rate-control" id="rateControlSection" style="margin-top: 15px; padding-top: 15px; border-top: 1px solid rgba(255,255,255,0.1);"></div>
                </div>
            </div>

            <!-- Level Info Banner -->
            <div class="level-info" id="levelInfo">
                <div class="level-progress">
                    <div class="level-details">
                        <i class="fas fa-chart-line"></i>
                        <span id="levelDescription">Complete sessions to level up!</span>
                    </div>
                    <div class="level-features" id="levelFeatures">
                        <!-- Dynamic level features -->
                    </div>
                </div>
            </div>

            <!-- Main Tabs -->
            <div class="dashboard-tabs">
                <button class="tab-btn active" data-tab="overview">
                    <i class="fas fa-chalkboard-user"></i> Overview
                </button>
                <button class="tab-btn" data-tab="requests">
                    <i class="fas fa-envelope"></i> Requests
                    <span class="badge" id="pendingCount">0</span>
                </button>
                <button class="tab-btn" data-tab="sessions">
                    <i class="fas fa-calendar-alt"></i> Sessions
                </button>
                <button class="tab-btn" data-tab="skills">
                    <i class="fas fa-code"></i> Skills
                </button>
                <button class="tab-btn" data-tab="earnings">
                    <i class="fas fa-wallet"></i> Earnings
                </button>
            </div>

            <!-- Tab Content: Overview -->
            <div class="tab-content active" id="overviewTab">
                <!-- Stats Grid -->
                <div class="stats-grid">
                    <div class="stat-card">
                        <i class="fas fa-users"></i>
                        <div class="stat-info">
                            <span class="stat-value" id="totalStudents">0</span>
                            <span class="stat-label">Students Taught</span>
                        </div>
                    </div>
                    <div class="stat-card">
                        <i class="fas fa-clock"></i>
                        <div class="stat-info">
                            <span class="stat-value" id="totalHours">0</span>
                            <span class="stat-label">Teaching Hours</span>
                        </div>
                    </div>
                    <div class="stat-card">
                        <i class="fas fa-star"></i>
                        <div class="stat-info">
                            <span class="stat-value" id="teacherRating">0</span>
                            <span class="stat-label">Rating</span>
                        </div>
                    </div>
                    <div class="stat-card">
                        <i class="fas fa-chart-line"></i>
                        <div class="stat-info">
                            <span class="stat-value" id="completionRate">0%</span>
                            <span class="stat-label">Completion Rate</span>
                        </div>
                    </div>
                </div>

                <!-- Trending Topics -->
                <div class="section-card">
                    <div class="section-header">
                        <h3><i class="fas fa-fire"></i> Trending Topics to Teach</h3>
                        <button class="refresh-btn" id="refreshTrending">
                            <i class="fas fa-sync-alt"></i>
                        </button>
                    </div>
                    <div class="trending-list" id="trendingList">
                        <div class="loading">Loading trending topics...</div>
                    </div>
                </div>

                <!-- Upcoming Sessions Preview -->
                <div class="section-card">
                    <div class="section-header">
                        <h3><i class="fas fa-calendar-week"></i> Upcoming Sessions</h3>
                        <a href="#" class="view-all" data-tab="sessions">View All →</a>
                    </div>
                    <div class="upcoming-preview" id="upcomingPreview">
                        <div class="loading">Loading upcoming sessions...</div>
                    </div>
                </div>
            </div>

            <!-- Tab Content: Session Requests -->
            <div class="tab-content" id="requestsTab">
                <div class="requests-filter">
                    <button class="filter-chip active" data-filter="all">All</button>
                    <button class="filter-chip" data-filter="pending">Pending</button>
                    <button class="filter-chip" data-filter="accepted">Accepted</button>
                    <button class="filter-chip" data-filter="rejected">Rejected</button>
                </div>
                <div class="requests-list" id="requestsList">
                    <div class="loading">Loading requests...</div>
                </div>
            </div>

            <!-- Tab Content: Sessions Management -->
            <div class="tab-content" id="sessionsTab">
                <div class="sessions-subtabs">
                    <button class="subtab-btn active" data-subtab="upcoming">Upcoming</button>
                    <button class="subtab-btn" data-subtab="ongoing">Ongoing</button>
                    <button class="subtab-btn" data-subtab="completed">Completed</button>
                </div>
                <div class="sessions-list" id="sessionsList">
                    <div class="loading">Loading sessions...</div>
                </div>
            </div>

            <!-- Tab Content: Skills Management -->
            <div class="tab-content" id="skillsTab">
                <div class="section-header">
                    <h3><i class="fas fa-code"></i> Your Teaching Skills</h3>
                    <button class="add-btn" id="addSkillBtn">
                        <i class="fas fa-plus"></i> Add Skill
                    </button>
                </div>
                <div class="skills-grid" id="skillsList">
                    <div class="loading">Loading skills...</div>
                </div>
            </div>

            <!-- Tab Content: Earnings -->
            <div class="tab-content" id="earningsTab">
                <div class="earnings-summary">
                    <div class="earning-card">
                        <i class="fas fa-coins"></i>
                        <div class="earning-info">
                            <span class="earning-label">Total Credits Earned</span>
                            <span class="earning-value" id="totalCreditsEarned">0</span>
                        </div>
                    </div>
                    <div class="earning-card">
                        <i class="fas fa-exchange-alt"></i>
                        <div class="earning-info">
                            <span class="earning-label">Redeemable Credits</span>
                            <span class="earning-value" id="redeemableCredits">0</span>
                        </div>
                    </div>
                    <div class="earning-card">
                        <i class="fas fa-rupee-sign"></i>
                        <div class="earning-info">
                            <span class="earning-label">Money Earned</span>
                            <span class="earning-value" id="moneyEarned">₹0</span>
                        </div>
                    </div>
                </div>
                
               

                <div class="transaction-history">
                    <h3><i class="fas fa-history"></i> Transaction History</h3>
                    <div class="transactions-list" id="transactionsList">
                        <div class="loading">Loading transactions...</div>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <!-- Add Skill Modal -->
    <div class="modal" id="addSkillModal">
        <div class="modal-content">
            <div class="modal-header">
                <h3><i class="fas fa-plus-circle"></i> Add Teaching Skill</h3>
                <button class="close-modal" id="closeSkillModal">&times;</button>
            </div>
            <form id="addSkillForm">
                <div class="form-group">
    <label>Skill Name *</label>
                    <input type="text" id="skillName" placeholder="e.g., JavaScript, Python, UI Design..." required>
                    <small>Enter the skill you want to teach</small>
                 </div>
                <div class="form-group">
                    <label>Proficiency Level</label>
                    <select id="proficiencyLevel">
                        <option value="beginner">Beginner</option>
                        <option value="intermediate">Intermediate</option>
                        <option value="advanced">Advanced</option>
                        <option value="expert">Expert</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>Years of Experience</label>
                    <input type="number" id="yearsExperience" min="0" step="0.5" value="0">
                </div>
                <div class="form-group" id="rateField" style="display: none;">
                    <label>Rate Per Session (Credits)</label>
                    <input type="number" id="hourlyRate" min="1" step="1">
                    <small id="rateHint"></small>
                </div>
                <button type="submit" class="submit-btn">Add Skill</button>
            </form>
        </div>
    </div>

<!-- Accept Request Modal -->
<div class="modal" id="acceptRequestModal">
    <div class="modal-content">
        <div class="modal-header">
            <h3><i class="fas fa-check-circle"></i> Accept Session Request</h3>
            <button class="close-modal" id="closeAcceptModal">&times;</button>
        </div>
        <form id="acceptRequestForm">
            <input type="hidden" id="acceptRequestId">
            <div class="request-details" id="requestDetails"></div>
            <div class="form-group">
                <label>Schedule Date <span style="font-weight: normal; color: #666;">(Optional - leave empty to use student's preferred date)</span></label>
                <input type="date" id="scheduleDate">
                <small>Leave empty to accept student's preferred date</small>
            </div>
            <div class="form-group">
                <label>Schedule Time <span style="font-weight: normal; color: #666;">(Optional - leave empty to use student's preferred time)</span></label>
                <input type="time" id="scheduleTime">
                <small>Leave empty to accept student's preferred time</small>
            </div>
            <button type="submit" class="accept-submit-btn">Confirm & Accept</button>
        </form>
    </div>
</div>

    <!-- Reject Request Modal -->
    <div class="modal" id="rejectRequestModal">
        <div class="modal-content">
            <div class="modal-header">
                <h3><i class="fas fa-times-circle"></i> Reject Session Request</h3>
                <button class="close-modal" id="closeRejectModal">&times;</button>
            </div>
            <form id="rejectRequestForm">
                <input type="hidden" id="rejectRequestId">
                <div class="form-group">
                    <label>Reason for Rejection</label>
                    <textarea id="rejectReason" rows="3" placeholder="Explain why you're rejecting this request..."></textarea>
                </div>
                <button type="submit" class="reject-submit-btn">Reject Request</button>
            </form>
        </div>
    </div>

    <!-- Start Session Modal -->
    <div class="modal" id="startSessionModal">
        <div class="modal-content">
            <div class="modal-header">
                <h3><i class="fas fa-play-circle"></i> Start Session</h3>
                <button class="close-modal" id="closeStartModal">&times;</button>
            </div>
            <div id="startSessionInfo"></div>
            <div class="session-code-box" id="sessionCodeBox" style="display: none;">
                <h4>Session Code</h4>
                <div class="code-display" id="sessionCode"></div>
                <button class="copy-code" id="copyCodeBtn">
                    <i class="fas fa-copy"></i> Copy Code
                </button>
            </div>
            <div class="meeting-link-box" id="meetingLinkBox" style="display: none;">
                <h4>Meeting Link</h4>
                <a href="#" id="meetingLinkDisplay" target="_blank" class="meeting-link">Join Meeting</a>
            </div>
            <div class="modal-actions">
                <button class="close-modal-btn" id="closeStartModalBtn">Close</button>
            </div>
        </div>
    </div>

   <%- include('partials/chat-modal') %>
  <!-- Group Session Creation Modal -->
<div class="modal" id="createGroupModal">
    <div class="modal-content">
        <div class="modal-header">
            <h3><i class="fas fa-users"></i> Create Group Session</h3>
            <button class="close-modal" id="closeGroupModal">&times;</button>
        </div>
        <form id="createGroupForm">
            <div class="form-group">
                <label>Skill *</label>
                <select id="groupSkillId" required>
                    <option value="">Select a skill...</option>
                </select>
            </div>
            <div class="form-group">
                <label>Session Title *</label>
                <input type="text" id="groupTitle" placeholder="e.g., Advanced JavaScript Workshop" required>
            </div>
            <div class="form-group">
                <label>Description</label>
                <textarea id="groupDescription" rows="3" placeholder="What will be covered?"></textarea>
            </div>
            <div class="form-group">
                <label>Credits per Student *</label>
                <input type="number" id="creditsPerStudent" min="1" step="1" required>
            </div>
            <div class="form-group">
                <label>Max Students (2-50) *</label>
                <input type="number" id="maxStudents" min="2" max="50" value="10" required>
            </div>
            <div class="form-group">
                <label>Date *</label>
                <input type="date" id="groupDate" required>
            </div>
            <div class="form-group">
                <label>Time *</label>
                <input type="time" id="groupTime" required>
            </div>
            <!-- Duration removed - default 60 minutes -->
            <input type="hidden" id="groupDuration" value="60">
            
            <button type="submit" class="submit-btn">Create Group Session</button>
        </form>
    </div>
</div>

<!-- Set Rate Modal -->
<div class="modal" id="setRateModal">
    <div class="modal-content">
        <div class="modal-header">
            <h3><i class="fas fa-tag"></i> Set Per-Session Rate</h3>
            <button class="close-modal" id="closeRateModal">&times;</button>
        </div>
        <form id="setRateForm">
            <div class="form-group">
                <label>Credits per Session *</label>
                <input type="number" id="sessionRate" min="1" step="1" required>
                <small>Set how many credits you want to earn per session</small>
            </div>
            <div class="info-box" style="background: #e3f2fd; padding: 12px; border-radius: 8px; margin: 15px 0;">
                <i class="fas fa-info-circle"></i>
                <span style="margin-left: 8px;">This rate will apply to all your future sessions</span>
            </div>
            <button type="submit" class="submit-btn">Update Rate</button>
        </form>
    </div>
</div>

    <script>
     // Get user data from EJS
const currentUser = {
    id: '<%= user && user._id ? user._id.toString() : "" %>',
    name: '<%= user && user.name ? user.name.replace(/'/g, "\\'") : "" %>',
    email: '<%= user && user.email ? user.email.replace(/'/g, "\\'") : "" %>',
    level: <%= user && user.level ? user.level : 1 %>
};

window.currentUser = currentUser;

        
        // Socket.io connection
        let socket = null;
        let currentConversationId = null;
        let currentChatStudent = null;
        
        // Helper functions
        function showToast(message, type = "info") {
            const toast = document.createElement('div');
            toast.className = `toast ${type}`;
            toast.innerHTML = `<i class="fas ${type === 'success' ? 'fa-check-circle' : type === 'error' ? 'fa-exclamation-circle' : 'fa-info-circle'}"></i><span>${escapeHtml(message)}</span>`;
            document.body.appendChild(toast);
            setTimeout(() => {
                toast.classList.add('show');
                setTimeout(() => {
                    toast.classList.remove('show');
                    setTimeout(() => toast.remove(), 300);
                }, 3000);
            }, 100);
        }
        
        function escapeHtml(text) {
            if (!text) return '';
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }
        
        function getRandomColor(str) {
            let hash = 0;
            for (let i = 0; i < str.length; i++) {
                hash = str.charCodeAt(i) + ((hash << 5) - hash);
            }
            const hue = hash % 360;
            return `hsl(${hue}, 70%, 60%)`;
        }
        
        // API Calls
        async function fetchTeacherProfile() {
            try {
                const response = await fetch('/api/teacher/profile');
                const data = await response.json();
              if (data.success) {
    document.getElementById('teacherLevel').textContent = data.data.level;
    document.getElementById('creditAmount').textContent = data.data.user.credits || 0;
    document.getElementById('totalEarned').textContent = data.data.user.totalCreditsEarned || 0;
    document.getElementById('creditRate').textContent = data.data.creditRate || 0;
    document.getElementById('teacherRating').textContent = data.data.user.rating || 0;
    document.getElementById('totalStudents').textContent = data.data.stats?.totalStudents || data.data.user.studentsCount || 0;
    document.getElementById('totalHours').textContent = data.data.stats?.totalHours || 0;
    document.getElementById('completionRate').textContent = `${data.data.stats?.completionRate || 0}%`;

    updateLevelFeatures(data.data);
    updateRateControl(data.data);
    return data.data;
}
            } catch (error) {
                console.error('Error fetching profile:', error);
            }
            return null;
        }
        
        function updateLevelFeatures(profileData) {
            const level = profileData.level;
            const features = profileData.features || {};
            
            const levelFeatures = document.getElementById('levelFeatures');
            let featuresHtml = '';
            
            if (level === 1) {
                featuresHtml = '<span class="feature-badge">📖 Fixed 1 credit/session</span><span class="feature-badge">🔒 No withdrawal</span>';
                document.getElementById('levelDescription').textContent = 'Level 1: Start teaching and earn 1 credit per session!';
            } else if (level === 2) {
                featuresHtml = '<span class="feature-badge">⭐ Admin-set credits</span><span class="feature-badge">🔒 No withdrawal</span>';
                document.getElementById('levelDescription').textContent = 'Level 2: Earn admin-set credits per session!';
            } else if (level === 3) {
                featuresHtml = '<span class="feature-badge">⭐ Admin-set credits</span><span class="feature-badge">💰 Withdrawal allowed</span>';
                document.getElementById('levelDescription').textContent = 'Level 3: Now you can withdraw your earnings!';
            } else if (level === 4) {
                featuresHtml = '<span class="feature-badge">🎯 Set your own rates</span><span class="feature-badge">💰 Withdrawal allowed</span><span class="feature-badge">👤 One-on-one only</span>';
                document.getElementById('levelDescription').textContent = 'Level 4: You control your pricing!';
            } else if (level === 5) {
                featuresHtml = '<span class="feature-badge">🎯 Set your own rates</span><span class="feature-badge">💰 Withdrawal allowed</span><span class="feature-badge">👥 Group sessions</span><span class="feature-badge">💬 Group chat</span>';
                document.getElementById('levelDescription').textContent = 'Level 5: Premium teacher - host group sessions!';
            }
            
            levelFeatures.innerHTML = featuresHtml;
            
           
            
            // Show/hide rate field in add skill modal
            const rateField = document.getElementById('rateField');
            const rateHint = document.getElementById('rateHint');
            if (level >= 4) {
                rateField.style.display = 'block';
                rateHint.textContent = `You can set your own rate (Current: ${profileData.creditRate} credits/session)`;
            } else {
                rateField.style.display = 'none';
            }
        }
        
        async function fetchTrendingTopics() {
            try {
                const response = await fetch('/api/teacher/trending-topics');
                const data = await response.json();
                if (data.success) {
                    renderTrendingTopics(data.data);
                }
            } catch (error) {
                console.error('Error fetching trending topics:', error);
            }
        }
        
        function renderTrendingTopics(data) {
            const container = document.getElementById('trendingList');
            const trending = data.trendingSkills || [];
            
            if (trending.length === 0) {
                container.innerHTML = '<div class="empty-state"><i class="fas fa-chart-line"></i><p>No trending topics yet</p></div>';
                return;
            }
            
            container.innerHTML = trending.map(skill => {
                const skillId = escapeHtml(skill._id);
                const skillName = escapeHtml(skill.name);
                const skillCategory = escapeHtml(skill.category);
                const totalTeachers = skill.totalTeachers || 0;
                const totalStudents = skill.totalStudents || 0;
                
                return `
                    <div class="trending-item">
                        <div class="trending-icon">
                            <i class="fas fa-chart-simple"></i>
                        </div>
                        <div class="trending-info">
                            <div class="trending-name">${skillName}</div>
                            <div class="trending-category">${skillCategory}</div>
                        </div>
                        <div class="trending-stats">
                            <span><i class="fas fa-users"></i> ${totalTeachers} teachers</span>
                            <span><i class="fas fa-graduation-cap"></i> ${totalStudents} students</span>
                        </div>
                        <button class="add-trending-skill" data-skill-id="${skillId}" data-skill-name="${skillName.replace(/'/g, "\\'")}">
                            <i class="fas fa-plus"></i> Add Skill
                        </button>
                    </div>
                `;
            }).join('');
            
            document.querySelectorAll('.add-trending-skill').forEach(btn => {
    btn.addEventListener('click', () => {
        const skillName = btn.getAttribute('data-skill-name') || '';
        const skillNameInput = document.getElementById('skillName');
        if (skillNameInput) {
            skillNameInput.value = skillName;
        }
        document.getElementById('addSkillModal').classList.add('show');
        showToast(`Adding ${skillName || 'skill'} to your skills`, 'info');
    });
});
        }
        
        async function fetchTeacherSkills() {
            try {
                const response = await fetch('/api/teacher/skills');
                const data = await response.json();
                if (data.success) {
                    renderTeacherSkills(data.data);
                }
            } catch (error) {
                console.error('Error fetching skills:', error);
            }
        }
        
        function renderTeacherSkills(skills) {
            const container = document.getElementById('skillsList');
            
            if (!skills || skills.length === 0) {
                container.innerHTML = `
                    <div class="empty-state">
                        <i class="fas fa-code"></i>
                        <p>No teaching skills added yet</p>
                        <button class="add-skill-empty" id="addSkillEmptyBtn">Add Your First Skill</button>
                    </div>
                `;
                const addBtn = document.getElementById('addSkillEmptyBtn');
                if(addBtn) {
                    addBtn.addEventListener('click', () => {
                        document.getElementById('addSkillModal').classList.add('show');
                    });
                }
                return;
            }
            
            container.innerHTML = skills.map(skill => {
                const skillId = escapeHtml(skill.skill ? skill.skill._id : '');
                const skillName = escapeHtml(skill.skill ? skill.skill.name : '');
                const skillCategory = skill.skill ? skill.skill.category : '';
                const proficiencyLevel = escapeHtml(skill.proficiencyLevel || 'beginner');
                const yearsOfExperience = skill.yearsOfExperience || 0;
                const hourlyRate = skill.hourlyRate || 0;
                const isAvailable = skill.isAvailable !== false;
                const skillIcon = getSkillIcon(skillCategory);
                const skillDataJson = JSON.stringify({
                    skill: skill.skill,
                    proficiencyLevel: proficiencyLevel,
                    yearsOfExperience: yearsOfExperience,
                    hourlyRate: hourlyRate,
                    isAvailable: isAvailable
                }).replace(/</g, '\\u003c').replace(/>/g, '\\u003e').replace(/&/g, '\\u0026').replace(/'/g, '\\u0027');
                
                return `
                    <div class="skill-card">
                        <div class="skill-header">
                            <div class="skill-name">
                                <i class="fas fa-${skillIcon}"></i>
                                ${skillName}
                            </div>
                            <div class="skill-actions">
                                <button class="edit-skill" data-skill-id="${skillId}" data-skill-data="${skillDataJson}">
                                    <i class="fas fa-edit"></i>
                                </button>
                                <button class="delete-skill" data-skill-id="${skillId}">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>
                        </div>
                        <div class="skill-details">
                            <span class="skill-badge">${proficiencyLevel}</span>
                            <span class="skill-badge"><i class="fas fa-clock"></i> ${yearsOfExperience} years</span>
                            <span class="skill-badge"><i class="fas fa-coins"></i> ${hourlyRate} credits/session</span>
                            <span class="skill-badge ${isAvailable ? 'available' : 'unavailable'}">
                                <i class="fas ${isAvailable ? 'fa-check-circle' : 'fa-clock'}"></i>
                                ${isAvailable ? 'Available' : 'Unavailable'}
                            </span>
                        </div>
                    </div>
                `;
            }).join('');
            
            document.querySelectorAll('.edit-skill').forEach(btn => {
                btn.addEventListener('click', () => {
                    try {
                        const skillDataRaw = btn.getAttribute('data-skill-data');
                        if (skillDataRaw) {
                            const skillData = JSON.parse(skillDataRaw);
                            editSkill(skillData);
                        }
                    } catch(e) {
                        console.error('Error parsing skill data', e);
                    }
                });
            });
            
            document.querySelectorAll('.delete-skill').forEach(btn => {
                btn.addEventListener('click', () => {
                    const skillId = btn.getAttribute('data-skill-id');
                    if (skillId) deleteSkill(skillId);
                });
            });
        }
        
        function getSkillIcon(category) {
            const icons = {
                'Programming': 'code',
                'Data Science': 'chart-line',
                'Design': 'paintbrush',
                'Business': 'briefcase',
                'Language': 'language',
                'Marketing': 'bullhorn',
                'Other': 'star'
            };
            return icons[category] || 'graduation-cap';
        }
        
        async function editSkill(skillData) {
            const newProficiency = prompt('Enter proficiency level (beginner/intermediate/advanced/expert):', skillData.proficiencyLevel);
            if (newProficiency && ['beginner', 'intermediate', 'advanced', 'expert'].includes(newProficiency)) {
                const newYears = prompt('Enter years of experience:', skillData.yearsOfExperience);
                const isAvailable = confirm('Are you available for teaching this skill? Click OK for Yes, Cancel for No');
                
                try {
                    const response = await fetch(`/api/teacher/skills/${skillData.skill._id}`, {
                        method: 'PUT',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            proficiencyLevel: newProficiency,
                            yearsOfExperience: parseFloat(newYears) || 0,
                            isAvailable: isAvailable
                        })
                    });
                    const data = await response.json();
                    if (data.success) {
                        showToast('Skill updated successfully', 'success');
                        fetchTeacherSkills();
                    } else {
                        showToast(data.message || 'Failed to update skill', 'error');
                    }
                } catch (error) {
                    console.error('Error updating skill:', error);
                    showToast('Failed to update skill', 'error');
                }
            }
        }
        
        async function deleteSkill(skillId) {
            if (confirm('Are you sure you want to remove this skill?')) {
                try {
                    const response = await fetch(`/api/teacher/skills/${skillId}`, {
                        method: 'DELETE'
                    });
                    const data = await response.json();
                    if (data.success) {
                        showToast('Skill removed successfully', 'success');
                        fetchTeacherSkills();
                    } else {
                        showToast(data.message || 'Failed to remove skill', 'error');
                    }
                } catch (error) {
                    console.error('Error removing skill:', error);
                    showToast('Failed to remove skill', 'error');
                }
            }
        }

        // Update rate control UI based on teacher level
function updateRateControl(profileData) {
    const rateControlSection = document.getElementById('rateControlSection');
    if (!rateControlSection) return;
    
    const level = profileData.level;
    const currentRate = profileData.creditRate;
    
    if (level >= 4) {
        // Eligible: Show rate setting option
        rateControlSection.innerHTML = `
            <div class="rate-message">
                <i class="fas fa-star"></i> Level ${level} - You can set your own rate!
            </div>
            <div class="current-rate">
                Current Rate: ${currentRate} credits/session
            </div>
            <button class="set-rate-btn" id="openRateModalBtn">
                <i class="fas fa-edit"></i> Change Rate
            </button>
        `;
        
        // Add event listener for rate button
        const openRateBtn = document.getElementById('openRateModalBtn');
        if (openRateBtn) {
            openRateBtn.addEventListener('click', () => {
                document.getElementById('setRateModal').classList.add('show');
                const rateInput = document.getElementById('sessionRate');
                if (rateInput) rateInput.value = currentRate;
            });
        }
    } else {
        // Not eligible: Show lock message
        let requiredLevel = '';
        let message = '';
        
        if (level === 1) {
            requiredLevel = 'Level 4';
            message = 'Reach Level 4 to set custom rates. Level up!';
        } else if (level === 2) {
            requiredLevel = 'Level 4';
            message = 'Reach Level 4 and set your own rates.';
        } else if (level === 3) {
            requiredLevel = 'Level 4';
            message = 'You\'re almost there! Reach Level 4 to customize your session rates.';
        }
        
        rateControlSection.innerHTML = `
            <div class="rate-message warning">
                <i class="fas fa-lock"></i> Rate customization available at Level 4+
            </div>
            <div class="rate-message disabled">
                ${message}
            </div>
            <div class="current-rate" style="color: #9e9e9e;">
                Fixed Rate: ${currentRate} credits/session (Admin Set)
            </div>
        `;
    }
}

// Add set rate form handler
function setupRateForm() {
    const setRateForm = document.getElementById('setRateForm');
    if (!setRateForm) return;
    
    setRateForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        const rateInput = document.getElementById('sessionRate');
        const newRate = rateInput ? parseInt(rateInput.value) : null;
        
        if (!newRate || newRate < 1) {
            showToast('Please enter a valid rate (minimum 1 credit)', 'error');
            return;
        }
        
        try {
            const response = await fetch('/api/teacher/level/credit-rate', {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ creditRate: newRate })
            });
            
            const data = await response.json();
            
            if (data.success) {
                showToast(`Rate updated to ${newRate} credits/session!`, 'success');
                document.getElementById('setRateModal').classList.remove('show');
                // Refresh profile to update UI
                await fetchTeacherProfile();
                // Also update rate display
                document.getElementById('creditRate').textContent = newRate;
            } else {
                showToast(data.message || 'Failed to update rate', 'error');
            }
        } catch (error) {
            console.error('Error updating rate:', error);
            showToast('Failed to update rate', 'error');
        }
    });
}
        
