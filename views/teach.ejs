function openAcceptModal(request) {
    document.getElementById('acceptRequestId').value = request._id;
    const requestDetails = document.getElementById('requestDetails');
    if(requestDetails) {
        requestDetails.innerHTML = `
            <div class="request-summary">
                <p><strong>Student:</strong> ${escapeHtml(request.student ? request.student.name : 'Student')}</p>
                <p><strong>Skill:</strong> ${escapeHtml(request.skill ? request.skill.name : 'N/A')}</p>
                <p><strong>Title:</strong> ${escapeHtml(request.title || 'Session Request')}</p>
                <p><strong>Duration:</strong> ${request.duration || 60} minutes</p>
                <p><strong>Proposed Credits:</strong> ${request.proposedCredits || 0}</p>
                <p><strong>Student's Preferred Time:</strong> ${escapeHtml(request.preferredTime || 'Not specified')}</p>
            </div>
        `;
    }
    
    // Pre-fill with student's preferred date and time (as defaults)
    const scheduleDateInput = document.getElementById('scheduleDate');
    const scheduleTimeInput = document.getElementById('scheduleTime');
    
    if (scheduleDateInput && request.preferredDate) {
        const preferredDate = new Date(request.preferredDate);
        const year = preferredDate.getFullYear();
        const month = String(preferredDate.getMonth() + 1).padStart(2, '0');
        const day = String(preferredDate.getDate()).padStart(2, '0');
        scheduleDateInput.value = `${year}-${month}-${day}`;
    } else if (scheduleDateInput) {
        // Default to tomorrow if no preferred date
        const tomorrow = new Date();
        tomorrow.setDate(tomorrow.getDate() + 1);
        scheduleDateInput.value = tomorrow.toISOString().split('T')[0];
    }
    
    if (scheduleTimeInput && request.preferredTime) {
        scheduleTimeInput.value = request.preferredTime;
    }
    
    // Make the fields optional by adding placeholder text
    const dateLabel = document.querySelector('#scheduleDate')?.closest('.form-group')?.querySelector('label');
    if (dateLabel) dateLabel.innerHTML = 'Schedule Date <span style="font-weight: normal; color: #666;">(Optional - defaults to student\'s preference)</span>';
    
    const timeLabel = document.querySelector('#scheduleTime')?.closest('.form-group')?.querySelector('label');
    if (timeLabel) timeLabel.innerHTML = 'Schedule Time <span style="font-weight: normal; color: #666;">(Optional - defaults to student\'s preference)</span>';
    
    document.getElementById('acceptRequestModal').classList.add('show');
}
        
        function openRejectModal(requestId) {
            document.getElementById('rejectRequestId').value = requestId;
            document.getElementById('rejectRequestModal').classList.add('show');
