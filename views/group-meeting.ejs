<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Group Session - <%= session.title %> | skiLLup</title>
    <link rel="stylesheet" href="/meeting.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="/socket.io/socket.io.js"></script>
    <style>
        /* Group meeting specific styles */
        .participants-grid {
            position: absolute;
            top: 1rem;
            right: 1rem;
            background: rgba(0,0,0,0.7);
            padding: 0.5rem 1rem;
            border-radius: 20px;
            color: white;
            font-size: 0.875rem;
            z-index: 10;
        }
        
        .participants-list {
            position: absolute;
            top: 4rem;
            right: 1rem;
            background: rgba(0,0,0,0.9);
            padding: 0.75rem;
            border-radius: 8px;
            min-width: 200px;
            display: none;
            z-index: 10;
        }
        
        .participants-list.active {
            display: block;
        }
        
        .participant-item {
            padding: 0.25rem 0.5rem;
            color: white;
            font-size: 0.8rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }
        
        .participant-item .online-dot {
            width: 8px;
            height: 8px;
            background: #10b981;
            border-radius: 50%;
        }
        
        .video-grid.group {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 1rem;
            padding: 1rem;
        }
        
        .remote-video-container {
            position: relative;
            background: #1e293b;
            border-radius: 12px;
            overflow: hidden;
            aspect-ratio: 16/9;
        }
        
        .remote-video-container video {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
        
        .remote-video-container .participant-name {
            position: absolute;
            bottom: 0.5rem;
            left: 0.5rem;
            background: rgba(0,0,0,0.6);
            padding: 0.25rem 0.5rem;
            border-radius: 4px;
            font-size: 0.75rem;
            color: white;
        }
        
        .screen-share-btn {
            background: #4f46e5;
        }
        
        .screen-share-btn.active {
            background: #dc2626;
        }
        
        @media (max-width: 768px) {
            .video-grid.group {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <div class="meeting-container">
        <div class="meeting-header">
            <div class="meeting-info">
                <h1><i class="fas fa-users"></i> <%= session.title %></h1>
                <div class="meeting-details">
                    <span><i class="fas fa-chalkboard-user"></i> Teacher: <%= session.teacher.name %></span>
                    <span><i class="fas fa-users"></i> <span id="participantCount">1</span>/<%= session.maxStudents + 1 %> Participants</span>
                    <span><i class="fas fa-key"></i> Code: <span id="joinCodeDisplay"><%= session.joinCode %></span></span>
                </div>
            </div>
            <div class="participants-grid">
                <button id="toggleParticipantsBtn" class="control-icon">
                    <i class="fas fa-users"></i>
                    <span id="participantBadge">1</span>
                </button>
                <button class="end-call-btn" id="endCallBtn">
                    <i class="fas fa-phone-slash"></i> Leave
                </button>
            </div>
        </div>
        
        <div class="participants-list" id="participantsList">
            <div class="participant-item">
                <span class="online-dot"></span>
                <span>You (<%= user.name %>)</span>
                <span class="role-badge">(<%= session.isTeacher ? 'Teacher' : 'Student' %>)</span>
            </div>
        </div>
        
        <div class="video-grid group" id="videoGrid">
            <div class="video-container local-video">
                <video id="localVideo" autoplay playsinline muted></video>
                <div class="video-overlay">
                    <span class="participant-name">You (<%= user.name %>)</span>
                    <div class="video-controls-overlay">
                        <button class="control-icon" id="toggleMicBtn" title="Mute">
                            <i class="fas fa-microphone"></i>
                        </button>
                        <button class="control-icon" id="toggleVideoBtn" title="Turn off camera">
                            <i class="fas fa-video"></i>
                        </button>
                        <button class="control-icon screen-share-btn" id="screenShareBtn" title="Share screen">
                            <i class="fas fa-desktop"></i>
                        </button>
                    </div>
                </div>
            </div>
            <div id="remoteVideos"></div>
        </div>
        
        <div class="connection-status" id="connectionStatus">
            <i class="fas fa-spinner fa-pulse"></i> Connecting to session...
        </div>
        
        <div class="chat-sidebar" id="chatSidebar" style="display: none;">
            <div class="chat-header">
                <h3><i class="fas fa-comment-dots"></i> Group Chat</h3>
                <button class="close-chat" id="closeChatBtn">&times;</button>
            </div>
            <div class="chat-messages" id="meetingChatMessages">
                <div class="chat-message system">
                    <div class="message-bubble">Welcome to the group session!</div>
                </div>
            </div>
            <div class="chat-input">
                <input type="text" id="meetingChatInput" placeholder="Message everyone...">
                <button id="sendMeetingChatBtn"><i class="fas fa-paper-plane"></i></button>
            </div>
        </div>
        
        <button class="toggle-chat-btn" id="toggleChatBtn">
            <i class="fas fa-comment"></i>
        </button>
    </div>
    
    <script>
        const sessionData =  JSON.stringify(session) ;
        const currentUser =  JSON.stringify(user) ;
        const isTeacher =  session.isTeacher ;
        const maxParticipants =  session.maxStudents + 1 ;
    </script>
    <script src="/js/group-meeting.js"></script>
</body>
</html>