<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Learn Dashboard - skiLLup</title>
    <link rel="stylesheet" href="/learn.css">
    <link rel="stylesheet" href="/chat.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,400;14..32,500;14..32,600;14..32,700;14..32,800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="/socket.io/socket.io.js"></script>
</head>
<body>
    <div class="app-container">
        <!-- Sidebar -->
        <aside class="sidebar">
            <div class="logo">
                <span class="logo-icon">📚</span>
                <span class="logo-text">skillUp</span>
            </div>

            <nav class="nav-menu">
                <a href="/learn" class="nav-item active">
                    <span class="nav-icon">🎓</span>
                    <span>Learn</span>
                </a>
                <a href="/teach" class="nav-item">
                    <span class="nav-icon">👨‍🏫</span>
                    <span>Teach</span>
                </a>
                <a href="/store" class="nav-item">
                    <span class="nav-icon">🛒</span>
                    <span>Store</span>
                </a>
                <a href="/history" class="nav-item">
                    <span class="nav-icon">📜</span>
                    <span>History</span>
                </a>
                <a href="/roadmap" class="nav-item">
                    <span class="nav-icon">🗺️</span>
                    <span>Roadmap</span>
                </a>
                <a href="/settings" class="nav-item">
                    <span class="nav-icon">⚙️</span>
                    <span>Settings</span>
                </a>
            </nav>

            <div class="user-profile">
                <div class="avatar">
                    <%= user ? user.name.charAt(0).toUpperCase() + (user.name.split(' ')[1] ? user.name.split(' ')[1].charAt(0).toUpperCase() : '') : 'U' %>
                </div>
                <div class="user-info">
                    <span class="user-name"><%= user ? user.name : 'User' %></span>
                    <span class="user-email"><%= user ? user.email : 'user@example.com' %></span>
                </div>
            </div>
        </aside>

        <!-- Main -->
        <main class="main-content">
            <div class="top-bar">
                <div class="header-section">
                    <h1>Learn Dashboard</h1>
                    <p class="header-subtitle">Find teachers, send requests, and manage your upcoming learning sessions</p>
                </div>

                <div class="credits-card">
                    <div class="credits-icon">
                        <i class="fas fa-coins"></i>
                    </div>
                    <div class="credits-info">
                        <span class="credits-label">Available Credits</span>
                        <span class="credits-amount" id="creditAmount">0</span>
                    </div>
                    <button class="add-credits-btn" id="addCreditsBtn">
                        <i class="fas fa-plus"></i> Add
                    </button>
                </div>
            </div>

            <!-- Quick Stats -->
            <section class="learn-overview">
                <div class="overview-card">
                    <div class="overview-icon pending">
                        <i class="fas fa-hourglass-half"></i>
                    </div>
                    <div class="overview-content">
                        <span class="overview-label">Pending Requests</span>
                        <span class="overview-value" id="pendingOverviewCount">0</span>
                    </div>
                </div>

                <div class="overview-card">
                    <div class="overview-icon upcoming">
                        <i class="fas fa-calendar-check"></i>
                    </div>
                    <div class="overview-content">
                        <span class="overview-label">Upcoming Sessions</span>
                        <span class="overview-value" id="upcomingOverviewCount">0</span>
                    </div>
                </div>

                <div class="overview-card">
                    <div class="overview-icon rejected">
                        <i class="fas fa-ban"></i>
                    </div>
                    <div class="overview-content">
                        <span class="overview-label">Rejected Requests</span>
                        <span class="overview-value" id="rejectedOverviewCount">0</span>
                    </div>
                </div>
            </section>

            <!-- Search -->
            <section class="search-section">
                <div class="search-bar">
                    <i class="fas fa-search search-icon"></i>
                    <input
                        type="text"
                        id="searchInput"
                        placeholder="Search teachers by name or skill..."
                        class="search-input"
                    >
                    <button class="filter-btn" type="button">
                        <i class="fas fa-sliders-h"></i>
                    </button>
                </div>
            </section>

            <!-- Main Grid -->
            <div class="content-grid">
                <!-- Left: Teachers -->
                <section class="teachers-column">
                    <div class="section-header">
                        <h2><i class="fas fa-chalkboard-user"></i> Available Teachers</h2>
                        <span class="result-count" id="resultCount">Loading...</span>
                    </div>

                    <div class="teachers-scroll-container" id="teachersContainer">
                        <div class="teachers-list" id="teachersList">
                            <div class="loading-spinner">Loading teachers...</div>
                        </div>
                    </div>
                </section>

                <!-- Right: Workflow -->
                <aside class="sessions-column">
                    <!-- Pending -->
                    <div class="sessions-section pending-section">
                        <div class="section-header">
                            <h3><i class="fas fa-hourglass-half"></i> Pending Requests</h3>
                            <span class="badge pending-badge" id="pendingCount">0</span>
                        </div>
                        <div class="sessions-list" id="pendingSessionsList">
                            <div class="loading-sessions">Loading...</div>
                        </div>
                    </div>

                    <!-- Upcoming -->
                    <div class="sessions-section upcoming-section">
                        <div class="section-header">
                            <h3><i class="fas fa-calendar-check"></i> Upcoming Sessions</h3>
                            <span class="badge accepted-badge" id="upcomingCount">0</span>
                        </div>
                        <div class="sessions-list" id="upcomingSessionsList">
                            <div class="loading-sessions">Loading...</div>
                        </div>
                    </div>

                    <!-- Rejected -->
                    <div class="sessions-section rejected-section">
                        <div class="section-header">
                            <h3><i class="fas fa-times-circle"></i> Rejected Requests</h3>
                            <span class="badge rejected-badge" id="rejectedCount">0</span>
                        </div>
                        <div class="sessions-list" id="rejectedSessionsList">
                            <div class="loading-sessions">Loading...</div>
                        </div>
                    </div>
                </aside>
            </div>
        </main>
    </div>

    <!-- Request Session Modal -->
    <div class="modal" id="requestModal">
        <div class="modal-content">
            <div class="modal-header">
                <h3>
                    <i class="fas fa-calendar-plus"></i>
                    Request Session with <span id="requestTeacherName"></span>
                </h3>
                <button class="close-modal" id="closeRequestModalBtn">&times;</button>
            </div>

            <form id="sessionRequestForm">
                <input type="hidden" id="requestTeacherId">

                <div class="form-group">
                    <label>Skill to Learn *</label>
                    <input type="text" id="requestSkillName" placeholder="e.g. JavaScript, React, Python" required>
                </div>

                <div class="form-group">
                    <label>Session Title *</label>
                    <input type="text" id="requestTitle" placeholder="e.g. React Hooks Basics" required>
                </div>

                <div class="form-group">
                    <label>Description</label>
                    <textarea id="requestDescription" rows="3" placeholder="What exactly do you want to learn?"></textarea>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label>Preferred Date *</label>
                        <input type="date" id="requestDate" required>
                    </div>

                    <div class="form-group">
                        <label>Preferred Time *</label>
                        <input type="time" id="requestTime" required>
                    </div>
                </div>

                <button type="submit" class="submit-request-btn">Send Request</button>
            </form>
        </div>
    </div>

    <!-- Chat modal -->
    <%- include('partials/chat-modal') %>

    <script>
        const currentUser = {
            id: '<%= user ? user._id : "" %>',
            name: '<%= user ? user.name : "" %>',
            email: '<%= user ? user.email : "" %>'
        };

        let socket = null;
        let currentPage = 1;
        let isLoading = false;
        let hasMore = true;
        let currentSearchTerm = '';
        let currentChatTeacher = null;
        let currentConversationId = null;
        let acceptedRequestSessions = [];

        function escapeHtml(text) {
            if (!text) return '';
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }

        function showToast(message, type = 'info') {
            const toast = document.createElement('div');
            toast.className = `toast ${type}`;
            toast.innerHTML = `
                <i class="fas ${type === 'success' ? 'fa-check-circle' : type === 'error' ? 'fa-exclamation-circle' : 'fa-info-circle'}"></i>
                <span>${escapeHtml(message)}</span>
            `;
            document.body.appendChild(toast);

            setTimeout(() => {
                toast.classList.add('show');
                setTimeout(() => {
                    toast.classList.remove('show');
                    setTimeout(() => toast.remove(), 300);
                }, 2800);
            }, 100);
        }

        function getRandomColor(str = '') {
            let hash = 0;
            for (let i = 0; i < str.length; i++) {
                hash = str.charCodeAt(i) + ((hash << 5) - hash);
            }
            const hue = Math.abs(hash % 360);
            return `hsl(${hue}, 70%, 60%)`;
        }

        function getInitials(name = 'U') {
            return name
                .split(' ')
                .map(n => n[0])
                .join('')
                .toUpperCase()
                .substring(0, 2);
        }

        function formatDate(dateValue) {
            if (!dateValue) return 'Date not available';
            const date = new Date(dateValue);
            return date.toLocaleDateString('en-US', {
                day: 'numeric',
                month: 'short',
                year: 'numeric'
            });
        }

        function formatDateTime(dateValue) {
            if (!dateValue) return 'Not scheduled';
            const date = new Date(dateValue);
            return date.toLocaleString('en-US', {
                day: 'numeric',
                month: 'short',
                year: 'numeric',
                hour: '2-digit',
                minute: '2-digit'
            });
        }

        function combineDateAndTime(dateValue, timeValue) {
    if (!dateValue) return null;

    const date = new Date(dateValue);
    if (Number.isNaN(date.getTime())) return null;

    if (timeValue && typeof timeValue === 'string' && timeValue.includes(':')) {
        const [hours, minutes] = timeValue.split(':');
        date.setHours(Number(hours) || 0, Number(minutes) || 0, 0, 0);
    }

    return date.toISOString();
}

        async function fetchCredits() {
            try {
                const response = await fetch('/api/learn/credits');
                const data = await response.json();

                if (data.success) {
                    document.getElementById('creditAmount').textContent = (data.data.credits || 0).toLocaleString();
                }
            } catch (error) {
                console.error('Error fetching credits:', error);
            }
        }

        async function fetchTeachers(searchTerm = '', page = 1, append = false) {
            if (isLoading) return;
            isLoading = true;

            try {
                const url = `/api/learn/teachers/search?q=${encodeURIComponent(searchTerm)}&page=${page}&limit=10`;
                const response = await fetch(url);
                const data = await response.json();

                if (!data.success) {
                    throw new Error(data.message || 'Failed to load teachers');
                }

                const teachers = data.data || [];

                if (append) {
                    appendTeachers(teachers);
                } else {
                    renderTeachers(teachers);
                }

                hasMore = teachers.length === 10;
                const count = teachers.length;
                document.getElementById('resultCount').textContent = `${count} teacher${count !== 1 ? 's' : ''} shown`;
            } catch (error) {
                console.error('Error fetching teachers:', error);
                showToast('Failed to load teachers', 'error');
            } finally {
                isLoading = false;
            }
        }

        function renderTeachers(teachers) {
            const container = document.getElementById('teachersList');

            if (!teachers || teachers.length === 0) {
                container.innerHTML = `
                    <div class="no-results">
                        <i class="fas fa-search"></i>
                        <p>No teachers found</p>
                        <small>Try another name or skill</small>
                    </div>
                `;
                return;
            }

            container.innerHTML = teachers.map(teacher => {
                const initials = getInitials(teacher.name);
                const avatarColor = `linear-gradient(135deg, ${getRandomColor(teacher._id)}, ${getRandomColor(teacher._id + '2')})`;
                const teachingSkills = teacher.teachingSkills?.map(s => s.skill?.name || s.name).filter(Boolean).join(', ') || 'Teaching';
                const requestStatus = teacher.requestStatus;

                const teacherData = JSON.stringify({
                    _id: teacher._id,
                    name: teacher.name,
                    email: teacher.email || ''
                }).replace(/'/g, '&#39;');

                let actionButton = '';

                if (requestStatus === 'pending' || requestStatus === 'negotiating') {
                    actionButton = `
                        <button class="pending-btn" disabled>
                            <i class="fas fa-clock"></i> Request Pending
                        </button>
                    `;
                } else if (requestStatus === 'rejected') {
                    actionButton = `
                        <button class="request-btn" data-teacher='${teacherData}'>
                            <i class="fas fa-calendar-plus"></i> Request Again
                        </button>
                    `;
                } else {
                    actionButton = `
                        <button class="request-btn" data-teacher='${teacherData}'>
                            <i class="fas fa-calendar-plus"></i> Request Session
                        </button>
                    `;
                }

                return `
                    <div class="teacher-card" data-teacher-id="${teacher._id}">
                        <div class="teacher-avatar" style="background: ${avatarColor}">
                            ${initials}
                        </div>

                        <div class="teacher-info">
                            <div class="teacher-name">${escapeHtml(teacher.name)}</div>
                            <div class="teacher-skill">${escapeHtml(teachingSkills)}</div>
                            <div class="teacher-bio">
                                ${escapeHtml(teacher.bio?.substring(0, 100) || 'No bio added yet')}
                                ${teacher.bio?.length > 100 ? '...' : ''}
                            </div>

                            <div class="teacher-rating">
                                <i class="fas fa-star" style="color: #fbbf24; font-size: 12px;"></i>
                                <span class="rating-value">${teacher.rating || 0}</span>
                                <span class="rating-max">/ 5.0</span>
                                <span class="rating-count">(${teacher.totalReviews || 0} reviews)</span>
                            </div>
                        </div>

                        <div class="teacher-actions">
                            ${actionButton}
                        </div>
                    </div>
                `;
            }).join('');

            bindTeacherButtons();
        }

        function appendTeachers(teachers) {
            const container = document.getElementById('teachersList');

            teachers.forEach(teacher => {
                const initials = getInitials(teacher.name);
                const avatarColor = `linear-gradient(135deg, ${getRandomColor(teacher._id)}, ${getRandomColor(teacher._id + '2')})`;
                const teachingSkills = teacher.teachingSkills?.map(s => s.skill?.name || s.name).filter(Boolean).join(', ') || 'Teaching';
                const requestStatus = teacher.requestStatus;

                const teacherData = JSON.stringify({
                    _id: teacher._id,
                    name: teacher.name,
                    email: teacher.email || ''
                }).replace(/'/g, '&#39;');

                let actionButton = '';

                if (requestStatus === 'pending' || requestStatus === 'negotiating') {
                    actionButton = `
                        <button class="pending-btn" disabled>
                            <i class="fas fa-clock"></i> Request Pending
                        </button>
                    `;
                } else if (requestStatus === 'rejected') {
                    actionButton = `
                        <button class="request-btn" data-teacher='${teacherData}'>
                            <i class="fas fa-calendar-plus"></i> Request Again
                        </button>
                    `;
                } else {
                    actionButton = `
                        <button class="request-btn" data-teacher='${teacherData}'>
                            <i class="fas fa-calendar-plus"></i> Request Session
                        </button>
                    `;
                }

                const html = `
                    <div class="teacher-card" data-teacher-id="${teacher._id}">
                        <div class="teacher-avatar" style="background: ${avatarColor}">
                            ${initials}
                        </div>

                        <div class="teacher-info">
                            <div class="teacher-name">${escapeHtml(teacher.name)}</div>
                            <div class="teacher-skill">${escapeHtml(teachingSkills)}</div>
                            <div class="teacher-bio">
                                ${escapeHtml(teacher.bio?.substring(0, 100) || 'No bio added yet')}
                                ${teacher.bio?.length > 100 ? '...' : ''}
                            </div>
                            <div class="teacher-rating">
                                <i class="fas fa-star" style="color: #fbbf24; font-size: 12px;"></i>
                                <span class="rating-value">${teacher.rating || 0}</span>
                                <span class="rating-max">/ 5.0</span>
                                <span class="rating-count">(${teacher.totalReviews || 0} reviews)</span>
                            </div>
                        </div>

                        <div class="teacher-actions">
                            ${actionButton}
                        </div>
                    </div>
                `;

                container.insertAdjacentHTML('beforeend', html);
            });

            bindTeacherButtons();
        }

        function bindTeacherButtons() {
            document.querySelectorAll('.request-btn').forEach(btn => {
                btn.onclick = (e) => {
                    e.stopPropagation();
                    try {
                        const teacherData = JSON.parse(btn.getAttribute('data-teacher'));
                        openRequestModal(teacherData);
                    } catch (error) {
                        console.error('Error parsing teacher data:', error);
                        showToast('Failed to open request form', 'error');
                    }
                };
            });
        }

async function fetchSessionRequests() {
    try {
        const response = await fetch('/api/learn/session-requests');
        const data = await response.json();

        if (!data.success) {
            throw new Error(data.message || 'Failed to fetch requests');
        }

        const pending = data.data.pending || [];
        const rejected = data.data.rejected || [];
        const accepted = data.data.accepted || [];

        acceptedRequestSessions = accepted.map(request => {
            const session = request.session || {};

            return {
                _id: session._id || `accepted-request-${request._id}`,
                requestId: request._id,
                teacher: session.teacher || request.teacher || {},
                skill: session.skill || request.skill || {},
                title: session.title || request.title || request.skill?.name || 'Session',
                duration: session.duration || request.duration || 60,
                scheduledDate: session.scheduledDate || combineDateAndTime(request.currentProposedDate, request.currentStartTime),
                roomId: session.roomId || '',
                joinCode: session.joinCode || '',
                status: session.status || 'confirmed',
                fromAcceptedRequest: true
            };
        });

        renderPendingRequests(pending);
        renderRejectedRequests(rejected);

        document.getElementById('pendingCount').textContent = pending.length;
        document.getElementById('rejectedCount').textContent = rejected.length;
        document.getElementById('pendingOverviewCount').textContent = pending.length;
        document.getElementById('rejectedOverviewCount').textContent = rejected.length;
    } catch (error) {
        console.error('Error fetching session requests:', error);
        showToast('Failed to load requests', 'error');
    }
}

      async function fetchUpcomingSessions() {
    try {
        const response = await fetch('/api/learn/upcoming-sessions');
        const data = await response.json();

        if (!data.success) {
            throw new Error(data.message || 'Failed to fetch upcoming sessions');
        }

        const apiSessions = data.data || [];
        const mergedMap = new Map();

        apiSessions.forEach(session => {
            mergedMap.set(String(session._id), session);
        });

        acceptedRequestSessions.forEach(session => {
            const key = session._id ? String(session._id) : String(session.requestId);
            if (!mergedMap.has(key)) {
                mergedMap.set(key, session);
            }
        });

        const sessions = Array.from(mergedMap.values()).sort((a, b) => {
            const aTime = a.scheduledDate ? new Date(a.scheduledDate).getTime() : 0;
            const bTime = b.scheduledDate ? new Date(b.scheduledDate).getTime() : 0;
            return aTime - bTime;
        });

        renderUpcomingSessions(sessions);

        document.getElementById('upcomingCount').textContent = sessions.length;
        document.getElementById('upcomingOverviewCount').textContent = sessions.length;
    } catch (error) {
        console.error('Error fetching upcoming sessions:', error);
        document.getElementById('upcomingSessionsList').innerHTML = `
            <div class="empty-sessions">
                <i class="fas fa-calendar-times"></i>
                <p>Could not load upcoming sessions</p>
                <small>Please refresh and try again</small>
            </div>
        `;
    }
}

      function renderPendingRequests(pendingRequests) {
    const container = document.getElementById('pendingSessionsList');

    if (!pendingRequests || pendingRequests.length === 0) {
        container.innerHTML = `
            <div class="empty-sessions">
                <i class="fas fa-hourglass-half"></i>
                <p>No pending requests</p>
                <small>Your new requests will appear here</small>
            </div>
        `;
        return;
    }

    container.innerHTML = pendingRequests.map(request => {
        const teacher = request.teacher || {};
        const initials = getInitials(teacher.name || 'T');
        const statusText = request.status === 'negotiating' ? 'Negotiating' : 'Pending';
        const messageText = request.teacherMessage || request.studentMessage || '';
        const isStudentTurnWaiting = String(request.proposedBy) === String(currentUser.id);

        let actionHtml = '';

        if (request.status === 'pending') {
            actionHtml = `
                <div class="session-actions">
                    <span class="waiting-note"><i class="fas fa-hourglass-half"></i> Waiting for teacher response</span>
                    <button class="cancel-request-btn" data-request-id="${request._id}">
                        <i class="fas fa-times"></i> Cancel
                    </button>
                </div>
            `;
        } else if (request.status === 'negotiating' && isStudentTurnWaiting) {
            actionHtml = `
                <div class="session-actions">
                    <span class="waiting-note"><i class="fas fa-hourglass-half"></i> Waiting for teacher response</span>
                    <button class="cancel-request-btn" data-request-id="${request._id}">
                        <i class="fas fa-times"></i> Cancel
                    </button>
                </div>
            `;
        } else if (request.status === 'negotiating' && !isStudentTurnWaiting) {
            actionHtml = `
                <div class="session-actions student-negotiation-actions">
                    <button class="accept-request-btn" data-request-id="${request._id}">
                        <i class="fas fa-check-circle"></i> Accept
                    </button>
                    <button class="suggest-request-btn" data-request-id="${request._id}" data-duration="${request.duration || 60}">
                        <i class="fas fa-calendar-alt"></i> Suggest Slot
                    </button>
                    <button class="cancel-request-btn" data-request-id="${request._id}">
                        <i class="fas fa-times"></i> Reject
                    </button>
                </div>
            `;
        }

        return `
            <div class="session-card-item pending" data-request-id="${request._id}">
                <div class="session-card-header">
                    <div class="session-teacher">
                        <div class="session-avatar small" style="background: ${getRandomColor(teacher._id || teacher.name || 'T')}">
                            ${initials}
                        </div>
                        <div class="session-info">
                            <h4>${escapeHtml(teacher.name || 'Teacher')}</h4>
                            <span class="session-skill-tag">${escapeHtml(request.skill?.name || 'Skill')}</span>
                        </div>
                    </div>

                    <div class="session-status pending">
                        <i class="fas fa-hourglass-half"></i> ${statusText}
                    </div>
                </div>

                <div class="session-details">
                    <div class="session-detail-item">
                        <i class="fas fa-calendar-alt"></i>
                        <span>${formatDate(request.currentProposedDate)} at ${escapeHtml(request.currentStartTime || '--')}</span>
                    </div>

                    <div class="session-detail-item">
                        <i class="fas fa-clock"></i>
                        <span>${request.duration || 60} minutes</span>
                    </div>

                    <div class="session-detail-item">
                        <i class="fas fa-coins"></i>
                        <span>${request.proposedCredits || 0} credits</span>
                    </div>

                    ${messageText ? `
                        <div class="request-note">
                            <i class="fas fa-comment-alt"></i>
                            <span>${escapeHtml(messageText)}</span>
                        </div>
                    ` : ''}

                    ${actionHtml}
                </div>
            </div>
        `;
    }).join('');

    document.querySelectorAll('.cancel-request-btn').forEach(btn => {
        btn.onclick = async () => {
            const requestId = btn.dataset.requestId;
            await cancelSessionRequest(requestId);
        };
    });

    document.querySelectorAll('.accept-request-btn').forEach(btn => {
        btn.onclick = async () => {
            await acceptNegotiatedRequest(btn.dataset.requestId);
        };
    });

