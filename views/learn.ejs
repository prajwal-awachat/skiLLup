    const payload = {
        proposedDate: document.getElementById('studentSuggestDate').value,
        proposedStartTime: document.getElementById('studentSuggestTime').value,
        duration: 60,
        message: document.getElementById('studentSuggestMessage').value.trim()
    };

    try {
        const response = await fetch(`/api/learn/session-requests/${requestId}/suggest`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
        });

        const data = await response.json();

        if (data.success) {
            showToast('Counter offer sent', 'success');
            document.getElementById('studentSuggestModal').classList.remove('show');
            document.getElementById('studentSuggestForm').reset();
            await refreshRightPanel();
            await fetchTeachers(currentSearchTerm, 1, false);
        } else {
            showToast(data.message || 'Failed to send counter offer', 'error');
        }
    } catch (error) {
        console.error(error);
        showToast('Failed to send counter offer', 'error');
    }
}

