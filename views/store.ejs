<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Credits Store | Purchase Learning Credits</title>
    <link rel="stylesheet" href="/store.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700;14..32,800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
</head>
<body>
    <div class="app-container">
        <!-- Sidebar (copied from learn.ejs) -->
        <aside class="sidebar">
            <div class="logo">
                <span class="logo-icon">📚</span>
                <span class="logo-text">skiLLup</span>
            </div>
            <nav class="nav-menu">
                <a href="/learn" class="nav-item">
                    <span class="nav-icon">🎓</span>
                    <span>Learn</span>
                </a>
                <a href="/teach" class="nav-item">
                    <span class="nav-icon">👨‍🏫</span>
                    <span>Teach</span>
                </a>
                <a href="/store" class="nav-item active">
                    <span class="nav-icon">🛒</span>
                    <span>Store</span>
                </a>
                <a href="/history" class="nav-item">
                    <span class="nav-icon">📜</span>
                    <span>History</span>
                </a>
                <a href="/roadmap" class="nav-item">
                    <span class="nav-icon">🗺️</span>
                    <span>Roadmap</span>
                </a>
                <a href="/settings" class="nav-item">
                    <span class="nav-icon">⚙️</span>
                    <span>Settings</span>
                </a>
            </nav>
            <div class="user-profile">
                <div class="avatar"><%= user ? user.name.charAt(0).toUpperCase() + (user.name.split(' ')[1] ? user.name.split(' ')[1].charAt(0).toUpperCase() : '') : 'U' %></div>
                <div class="user-info">
                    <span class="user-name"><%= user ? user.name : 'User' %></span>
                    <span class="user-email"><%= user ? user.email : 'user@example.com' %></span>
                </div>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="main-content">
            <!-- Top Bar with Credits Card and Withdraw Button -->
            <div class="top-bar">
                <div class="header-section">
                    <h1>Credits Store</h1>
                    <p class="header-subtitle">Purchase credit packages using your wallet balance</p>
                </div>
                
                <div class="wallet-actions">
                    <!-- Credits Card -->
                    <div class="credits-card">
                        <div class="credits-icon">
                            <i class="fas fa-coins"></i>
                        </div>
                        <div class="credits-info">
                            <span class="credits-label">My Credits</span>
                            <span class="credits-amount" id="creditAmount">0</span>
                        </div>
                    </div>

                    <!-- Wallet Balance Card -->
                    <div class="wallet-card">
                        <div class="wallet-icon">
                            <i class="fas fa-wallet"></i>
                        </div>
                        <div class="wallet-info">
                            <span class="wallet-label">Wallet Balance</span>
                            <span class="wallet-amount" id="walletAmount">₹0</span>
                        </div>
                    </div>

                    <!-- Withdraw Button -->
                    <button class="withdraw-btn" id="withdrawBtn">
                        <i class="fas fa-hand-holding-usd"></i> Withdraw Credits
                    </button>
                </div>
            </div>

            <!-- Credit Plans Grid (Dynamic) -->
            <div class="credit-plans-container">
                <div class="section-header">
                    <h2><i class="fas fa-gem"></i> Available Credit Packages</h2>
                    <span class="package-count" id="packageCount">Loading packages...</span>
                </div>
                <div class="credit-plans" id="creditPlansContainer">
                    <div class="loading-spinner">Loading packages...</div>
                </div>
            </div>

            <!-- Transaction History Section -->
            <div class="transaction-section">
                <div class="section-header">
                    <h3><i class="fas fa-history"></i> Transaction History</h3>
                    <button class="btn-refresh" onclick="refreshHistory()">
                        <i class="fas fa-sync-alt"></i>
                    </button>
                </div>
                <div class="transaction-table-container">
                    <table class="transaction-table">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Description</th>
                                <th>Amount</th>
                                <th>Credits</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody id="transactionBody">
                            <tr><td colspan="5" class="loading-text">Loading transactions...</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </main>
    </div>

    <!-- Withdraw Modal -->
    <div class="modal" id="withdrawModal">
        <div class="modal-content">
            <div class="modal-header">
                <h3><i class="fas fa-hand-holding-usd"></i> Withdraw Credits</h3>
                <button class="close-modal" id="closeWithdrawModalBtn">&times;</button>
            </div>
            <div class="modal-body">
                <div class="info-box">
                    <i class="fas fa-info-circle"></i>
                    <p>1 credit = ₹10<br>Minimum withdrawal: 10 credits</p>
                </div>
                <div class="form-group">
                    <label>Available Credits: <strong id="availableCredits">0</strong></label>
                    <input type="number" id="withdrawAmount" placeholder="Enter credits to withdraw" min="10" step="1">
                </div>
                <div class="withdraw-preview">
                    <span>You will receive:</span>
                    <strong id="previewAmount">₹0</strong>
                </div>
            </div>
            <div class="modal-actions">
                <button class="cancel-btn" id="cancelWithdrawBtn">Cancel</button>
                <button class="confirm-withdraw-btn" id="confirmWithdrawBtn">
                    <i class="fas fa-check"></i> Confirm Withdrawal
                </button>
            </div>
        </div>
    </div>

    <!-- Level Withdrawal Info Banner -->
<div class="level-withdraw-info" id="levelWithdrawInfo" style="display: none;">
    <i class="fas fa-info-circle"></i>
    <div class="info-text">
        <strong id="withdrawLevelStatus">Loading...</strong>
        <span id="withdrawLevelMessage"></span>
    </div>
    <div class="level-badge" id="userLevelBadge">Level 1</div>
</div>


  <script>
    const currentUser = {
        id: '<%= user ? user._id : "" %>',
        name: '<%= user ? user.name : "" %>',
        balance: <%= user ? user.balance || 0 : 0 %>,
        credits: <%= user ? user.credits || 0 : 0 %>,
        level: <%= user ? user.level || 1 : 1 %>
    };

    let creditPackages = [];

    function showToast(message, type = "info") {
        const toast = document.createElement('div');
        toast.className = `toast ${type}`;
        toast.innerHTML = `<i class="fas ${type === 'success' ? 'fa-check-circle' : type === 'error' ? 'fa-exclamation-circle' : 'fa-info-circle'}"></i> ${message}`;
        document.body.appendChild(toast);
        setTimeout(() => toast.remove(), 3000);
    }

    async function fetchUserData() {
        try {
            // FIXED: Changed from /api/user/balance to /api/store/balance
            const response = await fetch('/api/store/balance');
            const data = await response.json();
            if (data.success) {
                document.getElementById('creditAmount').textContent = data.data.credits;
                document.getElementById('walletAmount').textContent = `₹${data.data.balance}`;
                currentUser.credits = data.data.credits;
                currentUser.balance = data.data.balance;
                currentUser.level = data.data.level;
                
                // Update withdrawal UI based on level
                updateWithdrawalUI(data.data);
                return data.data;
            }
        } catch (error) {
            console.error('Error fetching user data:', error);
        }
        return null;
    }
    
    // Update withdrawal UI based on level
    function updateWithdrawalUI(userData) {
        const level = userData.level;
        const withdrawBtn = document.getElementById('withdrawBtn');
        const levelInfoBanner = document.getElementById('levelWithdrawInfo');
        const userLevelBadge = document.getElementById('userLevelBadge');
        const withdrawLevelStatus = document.getElementById('withdrawLevelStatus');
        const withdrawLevelMessage = document.getElementById('withdrawLevelMessage');
        
        if (userLevelBadge) {
            userLevelBadge.textContent = `Level ${level}`;
        }
        
        if (levelInfoBanner) {
            levelInfoBanner.style.display = 'flex';
        }
        
        if (level === 1 || level === 2) {
            // Cannot withdraw
            if (withdrawBtn) {
                withdrawBtn.title = `Level ${level} teachers cannot withdraw credits. Reach Level 3 to withdraw.`;
            }
            if (withdrawLevelStatus) {
                withdrawLevelStatus.innerHTML = '<i class="fas fa-lock"></i> Withdrawal Not Available';
                withdrawLevelStatus.style.color = '#fbbf24';
            }
            if (withdrawLevelMessage) {
                withdrawLevelMessage.textContent = `Level ${level} teachers cannot withdraw credits. Reach Level 3.`;
            }
            if (levelInfoBanner) {
                levelInfoBanner.style.background = 'linear-gradient(135deg, #f59e0b 0%, #d97706 100%)';
            }
        } else if (level >= 3) {
            // Can withdraw
            if (withdrawBtn) {
                withdrawBtn.title = `Level ${level} - You can withdraw credits (1 credit = ₹10)`;
            }
            if (withdrawLevelStatus) {
                withdrawLevelStatus.innerHTML = '<i class="fas fa-check-circle"></i> Withdrawal Available';
                withdrawLevelStatus.style.color = '#10b981';
            }
            if (withdrawLevelMessage) {
                withdrawLevelMessage.textContent = `Level ${level}: You can withdraw your credits! Minimum 10 credits. 1 credit = ₹10.`;
            }
            if (levelInfoBanner) {
                levelInfoBanner.style.background = 'linear-gradient(135deg, #10b981 0%, #059669 100%)';
            }
        }
    }

    async function fetchCreditPackages() {
        try {
            const response = await fetch('/api/store/packages');
            const data = await response.json();
            if (data.success) {
                creditPackages = data.data;
                renderCreditPackages(data.data);
                document.getElementById('packageCount').textContent = `${data.data.length} packages available`;
            }
        } catch (error) {
            console.error('Error fetching packages:', error);
            document.getElementById('creditPlansContainer').innerHTML = '<div class="error">Failed to load packages</div>';
        }
    }

    function renderCreditPackages(packages) {
        const container = document.getElementById('creditPlansContainer');
        
        if (!packages || packages.length === 0) {
            container.innerHTML = '<div class="no-results">No credit packages available at the moment</div>';
            return;
        }

        container.innerHTML = packages.map(pkg => `
            <div class="plan-card ${pkg.isPopular ? 'featured' : ''}">
                ${pkg.isPopular ? '<div class="plan-badge">POPULAR</div>' : ''}
                <div class="plan-header">
                    <h2 class="plan-credits">${pkg.credits} Credits</h2>
                    <div class="plan-price">
                        <span class="currency">₹</span>
                        <span class="amount">${pkg.price}</span>
                    </div>
                    ${pkg.originalPrice ? `<div class="plan-savings">Save ₹${pkg.originalPrice - pkg.price}</div>` : ''}
                </div>
                <div class="plan-features">
                    ${pkg.features.map(feature => `
                        <div class="feature-item">
                            <i class="fas fa-check-circle"></i>
                            <span>${feature}</span>
                        </div>
                    `).join('')}
                    <div class="feature-item">
                        <i class="fas fa-calendar-alt"></i>
                        <span>Valid ${pkg.validityDays} days</span>
                    </div>
                </div>
                <button class="btn-buy" onclick="purchasePackage('${pkg._id}', ${pkg.credits}, ${pkg.price})">
                    Buy Now <i class="fas fa-arrow-right"></i>
                </button>
            </div>
        `).join('');
    }

    async function purchasePackage(packageId, credits, price) {
        const userBalance = currentUser.balance;
        
        if (userBalance < price) {
            showToast(`Insufficient balance! Need ₹${price - userBalance} more.`, 'error');
            return;
        }

        const confirmPurchase = confirm(`Purchase ${credits} credits for ₹${price}?\n\nThis will deduct ₹${price} from your wallet balance.`);
        
        if (!confirmPurchase) return;

        try {
            const response = await fetch('/api/store/purchase', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ packageId })
            });

            const data = await response.json();

            if (data.success) {
                showToast(`Successfully purchased ${credits} credits!`, 'success');
                await fetchUserData();
                await fetchTransactionHistory();
                currentUser.balance = data.data.newBalance;
                currentUser.credits = data.data.newCredits;
            } else {
                showToast(data.message || 'Purchase failed', 'error');
            }
        } catch (error) {
            console.error('Error purchasing:', error);
            showToast('Failed to complete purchase', 'error');
        }
    }

    async function fetchTransactionHistory() {
        try {
            // FIXED: Changed from /api/user/transactions to /api/store/transactions
            const response = await fetch('/api/store/transactions');
            const data = await response.json();
            if (data.success) {
                renderTransactions(data.data);
            }
        } catch (error) {
            console.error('Error fetching transactions:', error);
        }
    }

    function renderTransactions(transactions) {
        const tbody = document.getElementById('transactionBody');
        
        if (!transactions || transactions.length === 0) {
            tbody.innerHTML = '<tr><td colspan="5" class="loading-text">No transactions found</td></tr>';
            return;
        }

        tbody.innerHTML = transactions.slice(0, 10).map(transaction => `
            <tr>
                <td>${new Date(transaction.createdAt).toLocaleDateString()}</td>
                <td>${transaction.description}</td>
                <td class="${transaction.amount > 0 ? 'positive' : 'negative'}">${transaction.amount > 0 ? '+' : ''}₹${Math.abs(transaction.amount)}</td>
                <td class="${transaction.credits > 0 ? 'positive' : 'negative'}">${transaction.credits > 0 ? '+' : ''}${transaction.credits}</td>
                <td><span class="status-badge success"><i class="fas fa-check-circle"></i> ${transaction.status}</span></td>
            </tr>
        `).join('');
    }

    // Withdraw functionality with level check
    document.getElementById('withdrawBtn')?.addEventListener('click', async () => {
        // Check level first
        const userLevel = currentUser.level;
        
        if (userLevel === 1 || userLevel === 2) {
            showToast(`Level ${userLevel} cannot withdraw credits. Reach Level 3 to withdraw!`, 'error');
            return;
        }
        
        // Check if user can redeem
        try {
            const eligibilityResponse = await fetch('/api/store/withdraw/check');
            const eligibilityData = await eligibilityResponse.json();
            
            if (!eligibilityData.success || !eligibilityData.data.canWithdraw) {
                showToast(eligibilityData.data.message, 'error');
                return;
            }
            
            const availableCredits = eligibilityData.data.redeemableCredits;
            if (availableCredits < 10) {
                showToast(`Minimum 10 credits required for withdrawal. You have ${availableCredits} redeemable credits.`, 'error');
                return;
            }
            
            document.getElementById('availableCredits').textContent = availableCredits;
            document.getElementById('withdrawModal').classList.add('show');
        } catch (error) {
            showToast('Failed to check withdrawal eligibility', 'error');
        }
    });

    document.getElementById('withdrawAmount')?.addEventListener('input', (e) => {
        const amount = parseInt(e.target.value) || 0;
        const preview = document.getElementById('previewAmount');
        preview.textContent = `₹${amount * 10}`;
    });

    document.getElementById('confirmWithdrawBtn')?.addEventListener('click', async () => {
        const credits = parseInt(document.getElementById('withdrawAmount').value);
        
        if (!credits || credits < 10) {
            showToast('Please enter at least 10 credits', 'error');
            return;
        }

        // Double-check level before processing
        if (currentUser.level === 1 || currentUser.level === 2) {
            showToast(`Level ${currentUser.level} cannot withdraw credits!`, 'error');
            document.getElementById('withdrawModal').classList.remove('show');
            return;
        }

        try {
            const response = await fetch('/api/store/withdraw', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ credits })
            });

            const data = await response.json();

            if (data.success) {
                showToast(data.message, 'success');
                document.getElementById('withdrawModal').classList.remove('show');
                document.getElementById('withdrawAmount').value = '';
                await fetchUserData();
                await fetchTransactionHistory();
                currentUser.credits = data.data.newCredits;
                currentUser.balance = data.data.newBalance;
            } else {
                showToast(data.message, 'error');
            }
        } catch (error) {
            showToast('Withdrawal failed', 'error');
        }
    });

    function closeModals() {
        document.getElementById('withdrawModal')?.classList.remove('show');
    }

    document.getElementById('closeWithdrawModalBtn')?.addEventListener('click', closeModals);
    document.getElementById('cancelWithdrawBtn')?.addEventListener('click', closeModals);
    document.getElementById('withdrawModal')?.addEventListener('click', (e) => {
        if (e.target === document.getElementById('withdrawModal')) closeModals();
    });

    function refreshHistory() {
        fetchTransactionHistory();
        showToast('Transaction history refreshed', 'success');
    }

    async function init() {
        await fetchUserData();
        await fetchCreditPackages();
        await fetchTransactionHistory();
    }

    document.addEventListener('DOMContentLoaded', init);
</script>
</body>
</html>