<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Skill Roadmap Generator | Multiple Learning Paths</title>
    <link rel="stylesheet" href="/sidebar.css">
    <link rel="stylesheet" href="/roadmap.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700;14..32,800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
</head>
<body>
    <div class="app-container">
        <!-- Sidebar (matching learn.ejs style) -->
       <%- include('partials/sidebar', { user: user, activePage: 'roadmap' }) %>

        <!-- Main Content -->
        <main class="main-content">
            <!-- Top Bar with Credits Card (matching learn.ejs style) -->
            <div class="top-bar">
                <div class="header-section">
                    <h1>Skill Roadmap Generator</h1>
                    <p class="header-subtitle">Chart your learning journey with an AI-generated plan</p>
                </div>
                <div class="credits-card">
                    <div class="credits-icon">
                        <i class="fas fa-coins"></i>
                    </div>
                    <div class="credits-info">
                        <span class="credits-label">Available Credits</span>
                        <span class="credits-amount" id="creditAmount">0</span>
                    </div>
                    <button class="add-credits-btn" id="addCreditsBtn"  onclick="window.location.href='/store'">
                        <i class="fas fa-plus"></i> Add
                    </button>
                </div>
            </div>

            <!-- Generate Button Section -->
            <div class="generate-section">
    <form id="roadmapForm" class="roadmap-form">
        <input
            type="text"
            id="goalInput"
            name="goal"
            placeholder="Enter your career goal (e.g. Web Developer, Data Analyst)"
            required
            class="roadmap-input"
        />

        <button type="submit" class="btn-generate">
            <i class="fas fa-magic"></i> Generate Roadmap
        </button>
    </form>
</div>

            <!-- Roadmaps Grid -->
            <div class="roadmaps-grid" id="roadmapsGrid">
                <!-- Roadmaps will be dynamically inserted here -->
            </div>
        </main>
    </div>

    <!-- Template for a single roadmap (hidden, used for cloning) -->
    <template id="roadmapTemplate">
        <div class="roadmap-card">
            <div class="roadmap-header-section">
                <div class="roadmap-title-section">
                    <h2 class="roadmap-title">Learning Roadmap</h2>
                    <button class="btn-delete-roadmap" title="Delete roadmap">
                        <i class="fas fa-trash-alt"></i>
                    </button>
                </div>
                <div class="roadmap-level">
                    <span class="level-label">Level</span>
                    <span class="level-value">4</span>
                    <span class="level-total">/ 13</span>
                </div>
                <div class="roadmap-progress">
                    <div class="progress-bar">
                        <div class="progress-fill" style="width: 0%"></div>
                    </div>
                </div>
            </div>

            <div class="roadmap-main-skill">
                <div class="skill-icon">
                    <i class="fab fa-python"></i>
                </div>
                <div class="skill-details">
                    <h3 class="skill-name">Python</h3>
                    <div class="skill-meta">
                        <span class="meta-item">
                            <i class="fas fa-chart-line"></i> Level: 4
                        </span>
                        <span class="meta-item">
                            <i class="fas fa-clock"></i> Time: 5 days
                        </span>
                    </div>
                </div>
            </div>

            <!-- Tabs for Skills and Courses -->
            <div class="roadmap-tabs">
                <button class="tab-btn active" data-tab="skills">
                    <i class="fas fa-code"></i> Skills <span class="tab-count">0</span>
                </button>
                <button class="tab-btn" data-tab="courses">
                    <i class="fas fa-book"></i> Courses <span class="tab-count">0</span>
                </button>
            </div>

            <!-- Skills List -->
            <div class="tab-content active" data-content="skills">
                <div class="skills-list"></div>
            </div>

            <!-- Courses List -->
            <div class="tab-content" data-content="courses">
                <div class="courses-list"></div>
            </div>
        </div>
    </template>

   <script>
    // Current logged-in user data
   const currentUser = {
    id: '<%= user ? user._id : "" %>',
    name: '<%= user ? user.name : "" %>',
    email: '<%= user ? user.email : "" %>',
    balance: <%= user ? user.balance || 0 : 0 %>,
    credits: <%= user ? user.credits || 0 : 0 %>,
    level: <%= user ? user.level || 1 : 1 %>
};

    // -----------------------------
    // Utility Functions
    // -----------------------------
    function showToast(message, type = 'info') {
        const toast = document.createElement('div');
        toast.className = `toast-message ${type}`;
        toast.innerHTML = `
            <i class="fas ${
                type === 'success'
                    ? 'fa-check-circle'
                    : type === 'error'
                    ? 'fa-exclamation-circle'
                    : 'fa-info-circle'
            }"></i>
            ${message}
        `;

        document.body.appendChild(toast);

        setTimeout(() => {
            toast.classList.add('show');

            setTimeout(() => {
                toast.classList.remove('show');

                setTimeout(() => {
                    toast.remove();
                }, 300);
            }, 3000);
        }, 100);
    }

async function fetchCredits() {
    try {
        // Same endpoint used in store.ejs
        const response = await fetch('/api/store/balance');
        const data = await response.json();

        if (response.ok && data.success) {
            // Update current user values
            currentUser.credits = data.data.credits || 0;
            currentUser.balance = data.data.balance || 0;
            currentUser.level = data.data.level || 1;

            // Update Available Credits in roadmap page
            const creditAmount = document.getElementById('creditAmount');
            if (creditAmount) {
                creditAmount.textContent =
                    currentUser.credits.toLocaleString();
            }
        } else {
            const creditAmount = document.getElementById('creditAmount');
            if (creditAmount) {
                creditAmount.textContent = '0';
            }
        }
    } catch (error) {
        console.error('Error fetching credits:', error);

        const creditAmount = document.getElementById('creditAmount');
        if (creditAmount) {
            creditAmount.textContent = '0';
        }
    }
}

    function escapeHtml(text) {
        if (!text) return '';

        const div = document.createElement('div');
        div.textContent = text;
        return div.innerHTML;
    }

    function checkEmptyState() {
        const grid = document.getElementById('roadmapsGrid');

        if (!grid) return;

        if (grid.children.length === 0) {
            grid.innerHTML = `
                <div class="empty-state">
                    <i class="fas fa-map-marked-alt"></i>
                    <h3>No Roadmaps Yet</h3>
                    <p>Enter your career goal and generate your first roadmap.</p>
                </div>
            `;
        }
    }

    // -----------------------------
    // API Calls
    // -----------------------------
    async function generateRoadmapFromAPI(goal) {
        const response = await fetch('/api/roadmap/generate', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({ goal })
        });

        const data = await response.json();

        if (!response.ok || !data.success) {
            throw new Error(data.message || 'Failed to generate roadmap.');
        }

        return data.roadmap;
    }

    async function deleteRoadmapFromAPI(roadmapId) {
        const response = await fetch(`/api/roadmap/${roadmapId}`, {
            method: 'DELETE'
        });

        const data = await response.json();

        if (!response.ok || !data.success) {
            throw new Error(data.message || 'Failed to delete roadmap.');
        }
    }

    async function toggleMilestoneInAPI(roadmapId, milestoneIndex) {
        const response = await fetch(
            `/api/roadmap/${roadmapId}/milestone`,
            {
                method: 'PATCH',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({
                    milestoneIndex
                })
            }
        );

        const data = await response.json();

        if (!response.ok || !data.success) {
            throw new Error(data.message || 'Failed to update progress.');
        }

        return data.roadmap;
    }

    // -----------------------------
    // Rendering Helpers
    // -----------------------------
    function getIconForCareer(predictedCareer) {
        const iconMap = {
            web_developer: 'fab fa-html5',
            fullstack_developer: 'fas fa-layer-group',
            backend_developer: 'fas fa-server',
            data_analyst: 'fas fa-chart-bar',
            data_scientist: 'fas fa-chart-line',
            ml_engineer: 'fas fa-brain',
            python_developer: 'fab fa-python',
            software_engineer: 'fas fa-laptop-code',
            mobile_app_developer: 'fas fa-mobile-alt',
            cybersecurity: 'fas fa-shield-alt',
            devops_engineer: 'fas fa-code-branch',
            cloud_engineer: 'fas fa-cloud',
            game_developer: 'fas fa-gamepad',
            blockchain_developer: 'fas fa-link'
        };

        return iconMap[predictedCareer] || 'fas fa-graduation-cap';
    }
// to load all roadmaps of logged in user
    async function fetchUserRoadmaps() {
    const response = await fetch('/api/roadmap');
    const data = await response.json();

    if (!response.ok || !data.success) {
        throw new Error(data.message || 'Failed to load roadmaps.');
    }

    return data.roadmaps;
}

    function createRoadmapCard(roadmap) {
        const template = document.getElementById('roadmapTemplate');

        if (!template) return null;

        const clone = template.content.cloneNode(true);
        const card = clone.querySelector('.roadmap-card');

        card.dataset.id = roadmap._id;

        // Title
        card.querySelector('.roadmap-title').textContent = roadmap.title;

        // Level
        card.querySelector('.level-value').textContent =
            roadmap.currentLevel || 1;
        card.querySelector('.level-total').textContent =
            '/ ' + (roadmap.targetLevel || roadmap.milestones.length);

        // Progress
        card.querySelector('.progress-fill').style.width =
            (roadmap.progress || 0) + '%';

        // Main Skill Title
        const skillNameElem = card.querySelector('.skill-name');
        skillNameElem.textContent = roadmap.predictedCareer
            .replace(/_/g, ' ')
            .replace(/\b\w/g, (c) => c.toUpperCase());

        // Icon
        const iconElem = card.querySelector('.skill-icon i');
        iconElem.className = getIconForCareer(
            roadmap.predictedCareer
        );

        // Meta Info
        const metaItems = card.querySelectorAll(
            '.skill-meta .meta-item'
        );

        if (metaItems.length >= 2) {
            metaItems[0].innerHTML = `
                <i class="fas fa-chart-line"></i>
                Level: ${roadmap.currentLevel || 1}
            `;

            metaItems[1].innerHTML = `
                <i class="fas fa-clock"></i>
                Time: ${roadmap.estimatedDays || 0} days
            `;
        }

        // Skills Tab Count
        const skillsTabCount = card.querySelector(
            '.tab-btn[data-tab="skills"] .tab-count'
        );
        skillsTabCount.textContent = roadmap.milestones.length;

        // Courses Tab Count
        const coursesTabCount = card.querySelector(
            '.tab-btn[data-tab="courses"] .tab-count'
        );
        coursesTabCount.textContent = roadmap.courses
            ? roadmap.courses.length
            : 0;

        // Skills List (Milestones)
        const skillsList = card.querySelector('.skills-list');
        skillsList.innerHTML = '';

        roadmap.milestones.forEach((milestone, index) => {
            const uniqueId = `milestone_${roadmap._id}_${index}`;

            const item = document.createElement('div');
            item.className = 'skill-item';

            item.innerHTML = `
                <input
                    type="checkbox"
                    id="${uniqueId}"
                    ${milestone.isCompleted ? 'checked' : ''}
                >
                <label for="${uniqueId}">
                    <i class="fas fa-check-circle"></i>
                    <span>${escapeHtml(milestone.title)}</span>
                </label>
            `;

            const checkbox = item.querySelector('input');

            checkbox.addEventListener('change', async () => {
                try {
                    const updatedRoadmap =
                        await toggleMilestoneInAPI(
                            roadmap._id,
                            index
                        );

                    // Re-render updated card
                    const newCard =
                        createRoadmapCard(updatedRoadmap);

                    card.replaceWith(newCard);

                    showToast(
                        'Progress updated successfully.',
                        'success'
                    );
                } catch (error) {
                    checkbox.checked = !checkbox.checked;

                    showToast(error.message, 'error');
                }
            });

            skillsList.appendChild(item);
        });

        // Courses List
        const coursesList = card.querySelector('.courses-list');
        coursesList.innerHTML = '';

        if (roadmap.courses && roadmap.courses.length > 0) {
            roadmap.courses.forEach((course) => {
                const item = document.createElement('div');
                item.className = 'course-item';

                item.innerHTML = `
                    <label>
                        <i class="fas fa-graduation-cap"></i>
                        <span>${escapeHtml(course.title)}</span>
                    </label>
                `;

                coursesList.appendChild(item);
            });
        } else {
            coursesList.innerHTML = `
                <div class="course-item">
                    <label>
                        <i class="fas fa-book"></i>
                        <span>No courses added yet</span>
                    </label>
                </div>
            `;
        }

        // Tab Switching
        const tabButtons = card.querySelectorAll('.tab-btn');
        const tabContents = card.querySelectorAll('.tab-content');

        tabButtons.forEach((button) => {
            button.addEventListener('click', () => {
                const tabName =
                    button.getAttribute('data-tab');

                tabButtons.forEach((btn) =>
                    btn.classList.remove('active')
                );

                tabContents.forEach((content) =>
                    content.classList.remove('active')
                );

                button.classList.add('active');

                const activeContent =
                    card.querySelector(
                        `.tab-content[data-content="${tabName}"]`
                    );

                if (activeContent) {
                    activeContent.classList.add('active');
                }
            });
        });

        // Delete Roadmap
        const deleteButton = card.querySelector(
            '.btn-delete-roadmap'
        );

        deleteButton.addEventListener('click', async () => {
            const confirmed = confirm(
                'Are you sure you want to delete this roadmap?'
            );

            if (!confirmed) return;

            try {
                await deleteRoadmapFromAPI(roadmap._id);

                card.remove();

                checkEmptyState();

                showToast(
                    'Roadmap deleted successfully.',
                    'success'
                );
            } catch (error) {
                showToast(error.message, 'error');
            }
        });

        return card;
    }

    // -----------------------------
    // Generate Roadmap Handler
    // -----------------------------
    async function handleGenerateRoadmap() {
        const input = document.getElementById('goalInput');

        if (!input) {
            showToast(
                'Goal input field not found.',
                'error'
            );
            return;
        }

        const goal = input.value.trim();

        if (!goal) {
            showToast(
                'Please enter your career goal.',
                'error'
            );
            return;
        }

        const button = document.querySelector(
            '#roadmapForm .btn-generate'
        );

        try {
            if (button) {
                button.disabled = true;
                button.innerHTML =
                    '<i class="fas fa-spinner fa-spin"></i> Generating...';
            }

            const roadmap =
                await generateRoadmapFromAPI(goal);

            const grid =
                document.getElementById('roadmapsGrid');

            // Remove empty state if present
            if (
                grid.firstElementChild &&
                grid.firstElementChild.classList.contains(
                    'empty-state'
                )
            ) {
                grid.innerHTML = '';
            }

            const card = createRoadmapCard(roadmap);

            if (card) {
                grid.prepend(card);

                card.scrollIntoView({
                    behavior: 'smooth',
                    block: 'center'
                });
            }

            input.value = '';

            showToast(
                'Roadmap generated successfully!',
                'success'
            );
        } catch (error) {
            showToast(error.message, 'error');
        } finally {
            if (button) {
                button.disabled = false;
                button.innerHTML =
                    '<i class="fas fa-magic"></i> Generate Roadmap';
            }
        }
    }

    // -----------------------------
    // Initialization
    // -----------------------------
   async function init() {
    await fetchCredits();

    const grid = document.getElementById('roadmapsGrid');
    grid.innerHTML = '';

    try {
        const roadmaps = await fetchUserRoadmaps();

        if (roadmaps.length === 0) {
            checkEmptyState();
        } else {
            roadmaps.forEach((roadmap) => {
                const card = createRoadmapCard(roadmap);

                if (card) {
                    grid.appendChild(card);
                }
            });
        }
    } catch (error) {
        console.error(error);
        checkEmptyState();
    }

    const form = document.getElementById('roadmapForm');

    if (form) {
        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            await handleGenerateRoadmap();
        });
    }
}

    document.addEventListener('DOMContentLoaded', init);
</script>
</body>
</html>