<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Learning History | Track Your Progress</title>
    <link rel="stylesheet" href="/history.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700;14..32,800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
</head>
<body>
    <div class="history-container">
        <!-- Header Section -->
        <header class="history-header">
            <div class="header-content">
                <h1>
                    <i class="fas fa-history"></i>
                    Learning History
                </h1>
                <p>Track your progress and review past sessions</p>
            </div>
        </header>

        <!-- Stats Cards Section -->
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-icon">
                    <i class="fas fa-calendar-alt"></i>
                </div>
                <div class="stat-info">
                    <h3 class="stat-value">5</h3>
                    <p class="stat-label">Total Sessions</p>
                </div>
            </div>
            
            <div class="stat-card">
                <div class="stat-icon">
                    <i class="fas fa-clock"></i>
                </div>
                <div class="stat-info">
                    <h3 class="stat-value">5.0</h3>
                    <p class="stat-label">Total Hours</p>
                </div>
            </div>
            
            <div class="stat-card">
                <div class="stat-icon">
                    <i class="fas fa-coins"></i>
                </div>
                <div class="stat-info">
                    <h3 class="stat-value">113</h3>
                    <p class="stat-label">Credits Spent</p>
                </div>
            </div>
        </div>

        <!-- Tabs Section -->
        <div class="tabs-section">
            <button class="tab-btn active" data-tab="sessions">
                <i class="fas fa-chalkboard-user"></i> Sessions
            </button>
            <button class="tab-btn" data-tab="earnings">
                <i class="fas fa-chart-line"></i> Earnings
            </button>
        </div>

        <!-- Sessions Content -->
        <div class="tab-content active" id="sessionsContent">
            <div class="sessions-list" id="sessionsList">
                <!-- Sessions will be dynamically populated -->
            </div>
        </div>

        <!-- Earnings Content (initially hidden) -->
        <div class="tab-content" id="earningsContent">
            <div class="earnings-summary">
                <div class="earnings-card">
                    <h3><i class="fas fa-chart-simple"></i> Earnings Overview</h3>
                    <div class="earnings-stats">
                        <div class="earning-stat">
                            <span class="earning-label">Total Earned</span>
                            <span class="earning-value">$0</span>
                        </div>
                        <div class="earning-stat">
                            <span class="earning-label">This Month</span>
                            <span class="earning-value">$0</span>
                        </div>
                        <div class="earning-stat">
                            <span class="earning-label">Pending Payout</span>
                            <span class="earning-value">$0</span>
                        </div>
                    </div>
                    <p class="earnings-note">Start teaching to see your earnings here!</p>
                </div>
            </div>
        </div>
    </div>

    <script>
        // Session data
        const sessions = [
            {
                id: 1,
                initials: "AC",
                teacherName: "Alex Chen",
                skill: "Python - Advanced Functions",
                date: "Mar 20, 2026",
                duration: 60,
                credits: 20,
                summary: "In this session, we covered advanced Python concepts including decorators, generators, and context managers. Alex provided excellent explanations and practical examples."
            },
            {
                id: 2,
                initials: "MG",
                teacherName: "Maria Garcia",
                skill: "UI Design Fundamentals",
                date: "Mar 18, 2026",
                duration: 45,
                credits: 25,
                summary: "Learned about color theory, typography, and layout principles. Maria shared great resources for UI design inspiration and best practices."
            },
            {
                id: 3,
                initials: "DP",
                teacherName: "David Park",
                skill: "React Hooks Deep Dive",
                date: "Mar 15, 2026",
                duration: 75,
                credits: 22,
                summary: "Explored useState, useEffect, useContext, and custom hooks. David demonstrated real-world applications and performance optimization techniques."
            },
            {
                id: 4,
                initials: "EW",
                teacherName: "Emma Wilson",
                skill: "Spanish Conversation Practice",
                date: "Mar 12, 2026",
                duration: 30,
                credits: 18,
                summary: "Practiced conversational Spanish focusing on everyday situations. Emma provided great feedback on pronunciation and grammar."
            }
        ];

        // Render sessions
        function renderSessions() {
            const sessionsList = document.getElementById('sessionsList');
            
            sessionsList.innerHTML = sessions.map(session => `
                <div class="session-card" data-id="${session.id}">
                    <div class="session-header">
                        <div class="session-initials">${session.initials}</div>
                        <div class="session-main-info">
                            <h3 class="session-skill">${session.skill}</h3>
                            <p class="session-teacher">
                                <i class="fas fa-chalkboard-user"></i> with ${session.teacherName}
                            </p>
                        </div>
                    </div>
                    
                    <div class="session-details">
                        <div class="detail-item">
                            <i class="fas fa-calendar-day"></i>
                            <span>${session.date}</span>
                        </div>
                        <div class="detail-item">
                            <i class="fas fa-hourglass-half"></i>
                            <span>${session.duration} min</span>
                        </div>
                        <div class="detail-item">
                            <i class="fas fa-coins"></i>
                            <span>${session.credits} credits</span>
                        </div>
                    </div>
                    
                    <div class="session-summary" id="summary-${session.id}" style="display: none;">
                        <div class="summary-content">
                            <i class="fas fa-quote-left"></i>
                            <p>${session.summary}</p>
                        </div>
                    </div>
                    
                    <button class="btn-view-summary" onclick="toggleSummary(${session.id})">
                        View Summary <i class="fas fa-chevron-down"></i>
                    </button>
                </div>
            `).join('');
        }

        // Toggle summary visibility
        function toggleSummary(sessionId) {
            const summaryElement = document.getElementById(`summary-${sessionId}`);
            const button = document.querySelector(`.session-card[data-id="${sessionId}"] .btn-view-summary`);
            
            if (summaryElement.style.display === 'none') {
                summaryElement.style.display = 'block';
                button.innerHTML = 'Hide Summary <i class="fas fa-chevron-up"></i>';
                button.classList.add('active');
            } else {
                summaryElement.style.display = 'none';
                button.innerHTML = 'View Summary <i class="fas fa-chevron-down"></i>';
                button.classList.remove('active');
            }
        }

        // Tab switching functionality
        function initTabs() {
            const tabBtns = document.querySelectorAll('.tab-btn');
            const tabContents = document.querySelectorAll('.tab-content');
            
            tabBtns.forEach(btn => {
                btn.addEventListener('click', () => {
                    const tabName = btn.getAttribute('data-tab');
                    
                    // Update active states
                    tabBtns.forEach(b => b.classList.remove('active'));
                    btn.classList.add('active');
                    
                    tabContents.forEach(content => content.classList.remove('active'));
                    
                    if (tabName === 'sessions') {
                        document.getElementById('sessionsContent').classList.add('active');
                    } else if (tabName === 'earnings') {
                        document.getElementById('earningsContent').classList.add('active');
                    }
                });
            });
        }

        // Initialize on page load
        document.addEventListener('DOMContentLoaded', () => {
            renderSessions();
            initTabs();
        });
    </script>
</body>
</html>